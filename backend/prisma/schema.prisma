generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  OWNER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  SENT_TO_STAFF
  PACKING
  PARTIALLY_PACKED
  PACKED
  PARTIALLY_DISPATCHED
  DISPATCHED
  DM_CREATED
  CONVERTED_TO_SALE
  PARTIALLY_PAID
  FULLY_PAID
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum OrderItemStatus {
  PENDING
  AVAILABLE
  PACKED
  PARTIALLY_PACKED
  SHORTAGE
  DISPATCHED
  RETURNED
  CANCELLED
}

enum PackingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIALLY_COMPLETED
  CANCELLED
}

enum DispatchStatus {
  CREATED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  PENDING_PAYMENT
  CANCELLED
  RETURNED
}

enum DeliveryMemoStatus {
  CREATED
  DISPATCHED
  DELIVERED
  PARTIALLY_PAID
  FULLY_PAID
  CONVERTED_TO_SALE
  RETURNED
  CANCELLED
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
  CREDIT
  ADVANCE
  REFUND
}

enum PaymentStatus {
  RECORDED
  PENDING_VERIFICATION
  VERIFIED
  MISMATCH
  CANCELLED
  REFUNDED
}

enum BillPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERPAID
  REFUNDED
  CANCELLED
}

enum ChequeStatus {
  RECEIVED
  DEPOSITED
  CLEARED
  BOUNCED
  RETURNED
  CANCELLED
}

enum StockMovementType {
  OPENING_STOCK
  STOCK_IN
  STOCK_OUT
  SALE
  DM
  ORDER_DISPATCH
  RETURN
  DAMAGE_LOSS
  MANUAL_ADJUSTMENT
}

enum CashSessionStatus {
  OPEN
  CLOSED
  REVIEWED
  LOCKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

enum CreditStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum SummaryStatus {
  DRAFT
  GENERATED
  REVIEWED
  LOCKED
  EXPORTED
}

enum ExportFormat {
  PDF
  CSV
}

enum ExportStatus {
  PENDING
  DONE
  FAILED
}

model User {
  id           String     @id @default(cuid())
  name         String
  mobile       String     @unique
  email        String?    @unique
  passwordHash String
  roleId       String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  role                   Role                 @relation(fields: [roleId], references: [id])
  ownedShops             Shop[]               @relation("ShopOwner")
  staffShopAccesses      StaffShopAccess[]
  customersCreated       Customer[]           @relation("CustomerCreatedBy")
  stockMovementsCreated  StockLedger[]        @relation("StockCreatedBy")
  stockMovementsApproved StockLedger[]        @relation("StockApprovedBy")
  ordersCreated          Order[]              @relation("OrderCreatedBy")
  ordersAssigned         Order[]              @relation("OrderAssignedStaff")
  orderEvents            OrderEvent[]
  packingTasks           PackingTask[]
  dispatches             Dispatch[]           @relation("DispatchBy")
  sales                  Sale[]               @relation("SaleStaff")
  deliveryMemos          DeliveryMemo[]       @relation("DeliveryMemoStaff")
  paymentsReceived       Payment[]            @relation("PaymentReceivedBy")
  paymentsVerified       Payment[]            @relation("PaymentVerifiedBy")
  cashSessions           CashSession[]        @relation("CashSessionStaff")
  cashSessionsReviewed   CashSession[]        @relation("CashSessionReviewedBy")
  creditOutstandings     CreditOutstanding[]  @relation("CreditCreatedBy")
  rateRequests           RateChangeRequest[]  @relation("RateRequestedBy")
  rateApprovals          RateChangeRequest[]  @relation("RateApprovedBy")
  correctionRequests     CorrectionRequest[]  @relation("CorrectionRequestedBy")
  correctionApprovals    CorrectionRequest[]  @relation("CorrectionApprovedBy")
  notifications          Notification[]
  auditLogs              AuditLog[]
  dailySummariesReviewed DailySummary[]       @relation("SummaryReviewedBy")
  dailySummaryExports    DailySummaryExport[]
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique
  users       User[]
  permissions Permission[]
}

model Permission {
  id     String @id @default(cuid())
  action String
  roleId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, action])
}

model Shop {
  id                 String       @id @default(cuid())
  name               String
  code               String       @unique
  city               String
  address            String?
  ownerId            String
  openingCash        Decimal      @default(0) @db.Decimal(12, 2)
  openingStockLocked Boolean      @default(false)
  upiId              String?
  upiName            String?
  status             RecordStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  owner              User                @relation("ShopOwner", fields: [ownerId], references: [id])
  staffAccesses      StaffShopAccess[]
  customers          Customer[]
  itemCategories     ItemCategory[]
  items              Item[]
  stockLedger        StockLedger[]
  orders             Order[]
  packingTasks       PackingTask[]
  dispatches         Dispatch[]
  sales              Sale[]
  deliveryMemos      DeliveryMemo[]
  payments           Payment[]
  cashSessions       CashSession[]
  creditOutstandings CreditOutstanding[]
  notifications      Notification[]
  dailySummaries     DailySummary[]

  @@index([ownerId])
}

model StaffShopAccess {
  id        String   @id @default(cuid())
  staffId   String
  shopId    String
  createdAt DateTime @default(now())

  staff User @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shop  Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([staffId, shopId])
  @@index([shopId])
}

model Customer {
  id                String       @id @default(cuid())
  shopId            String
  name              String
  phone             String?
  address           String?
  city              String?
  gstin             String?
  creditLimit       Decimal?     @db.Decimal(12, 2)
  outstandingAmount Decimal      @default(0) @db.Decimal(12, 2)
  notes             String?
  status            RecordStatus @default(ACTIVE)
  createdById       String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  shop               Shop                @relation(fields: [shopId], references: [id])
  createdBy          User                @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  orders             Order[]
  dispatches         Dispatch[]
  sales              Sale[]
  deliveryMemos      DeliveryMemo[]
  payments           Payment[]
  creditOutstandings CreditOutstanding[]

  @@index([shopId])
  @@index([phone])
}

model ItemCategory {
  id        String       @id @default(cuid())
  shopId    String
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop  Shop   @relation(fields: [shopId], references: [id])
  items Item[]

  @@unique([shopId, name])
}

model Item {
  id                  String       @id @default(cuid())
  shopId              String
  name                String
  sku                 String?
  categoryId          String?
  unit                String
  defaultSellingPrice Decimal      @default(0) @db.Decimal(12, 2)
  minimumAllowedPrice Decimal?     @db.Decimal(12, 2)
  purchasePrice       Decimal?     @db.Decimal(12, 2)
  mrp                 Decimal?     @db.Decimal(12, 2)
  minimumStock        Decimal      @default(0) @db.Decimal(12, 3)
  imageUrl            String?
  status              RecordStatus @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  shop              Shop               @relation(fields: [shopId], references: [id])
  category          ItemCategory?      @relation(fields: [categoryId], references: [id])
  stockLedger       StockLedger[]
  orderItems        OrderItem[]
  dispatchItems     DispatchItem[]
  saleItems         SaleItem[]
  deliveryMemoItems DeliveryMemoItem[]

  @@unique([shopId, sku])
  @@index([shopId, name])
}

model StockLedger {
  id            String            @id @default(cuid())
  shopId        String
  itemId        String
  movementType  StockMovementType
  quantityIn    Decimal           @default(0) @db.Decimal(12, 3)
  quantityOut   Decimal           @default(0) @db.Decimal(12, 3)
  referenceType String?
  referenceId   String?
  reason        String?
  createdById   String
  approvedById  String?
  createdAt     DateTime          @default(now())

  shop       Shop  @relation(fields: [shopId], references: [id])
  item       Item  @relation(fields: [itemId], references: [id])
  createdBy  User  @relation("StockCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("StockApprovedBy", fields: [approvedById], references: [id])

  @@index([shopId, itemId])
  @@index([referenceType, referenceId])
}

model Order {
  id                   String            @id @default(cuid())
  orderNumber          String
  shopId               String
  customerId           String
  createdById          String
  assignedStaffId      String?
  orderDate            DateTime          @default(now())
  expectedDispatchDate DateTime?
  priority             Priority          @default(NORMAL)
  status               OrderStatus       @default(DRAFT)
  paymentStatus        BillPaymentStatus @default(UNPAID)
  subtotal             Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount       Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount           Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount        Decimal           @default(0) @db.Decimal(12, 2)
  ownerNotes           String?
  staffNotes           String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  cancelledAt          DateTime?
  cancelReason         String?

  shop               Shop                @relation(fields: [shopId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  createdBy          User                @relation("OrderCreatedBy", fields: [createdById], references: [id])
  assignedStaff      User?               @relation("OrderAssignedStaff", fields: [assignedStaffId], references: [id])
  items              OrderItem[]
  events             OrderEvent[]
  packingTasks       PackingTask[]
  dispatches         Dispatch[]
  sales              Sale[]
  deliveryMemos      DeliveryMemo[]
  payments           Payment[]
  creditOutstandings CreditOutstanding[]

  @@unique([shopId, orderNumber])
  @@index([shopId, status])
  @@index([customerId])
}

model OrderItem {
  id                       String          @id @default(cuid())
  orderId                  String
  itemId                   String
  quantityOrdered          Decimal         @db.Decimal(12, 3)
  quantityPacked           Decimal         @default(0) @db.Decimal(12, 3)
  quantityDispatched       Decimal         @default(0) @db.Decimal(12, 3)
  quantityPending          Decimal         @default(0) @db.Decimal(12, 3)
  rate                     Decimal         @db.Decimal(12, 2)
  discountAmount           Decimal         @default(0) @db.Decimal(12, 2)
  lineTotal                Decimal         @db.Decimal(12, 2)
  status                   OrderItemStatus @default(PENDING)
  priceSource              String?
  lastCustomerRateSnapshot Decimal?        @db.Decimal(12, 2)
  recentRateSnapshot       Json?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item               Item                @relation(fields: [itemId], references: [id])
  dispatchItems      DispatchItem[]
  rateChangeRequests RateChangeRequest[]

  @@index([orderId])
  @@index([itemId])
}

model OrderEvent {
  id          String       @id @default(cuid())
  orderId     String
  eventType   String
  oldStatus   OrderStatus?
  newStatus   OrderStatus?
  note        String?
  createdById String
  createdAt   DateTime     @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([orderId])
}

model PackingTask {
  id          String        @id @default(cuid())
  orderId     String
  shopId      String
  staffId     String
  status      PackingStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  shop  Shop  @relation(fields: [shopId], references: [id])
  staff User  @relation(fields: [staffId], references: [id])

  @@index([orderId])
  @@index([shopId, status])
  @@index([staffId])
}

model Dispatch {
  id             String         @id @default(cuid())
  orderId        String?
  dmId           String?
  saleId         String?
  customerId     String?
  shopId         String
  dispatchedById String
  dispatchDate   DateTime       @default(now())
  status         DispatchStatus @default(CREATED)
  proofImageUrl  String?
  notes          String?
  createdAt      DateTime       @default(now())

  order        Order?         @relation(fields: [orderId], references: [id])
  deliveryMemo DeliveryMemo?  @relation(fields: [dmId], references: [id])
  sale         Sale?          @relation(fields: [saleId], references: [id])
  customer     Customer?      @relation(fields: [customerId], references: [id])
  shop         Shop           @relation(fields: [shopId], references: [id])
  dispatchedBy User           @relation("DispatchBy", fields: [dispatchedById], references: [id])
  items        DispatchItem[]

  @@index([shopId, dispatchDate])
  @@index([orderId])
}

model DispatchItem {
  id                 String  @id @default(cuid())
  dispatchId         String
  orderItemId        String
  itemId             String
  quantityDispatched Decimal @db.Decimal(12, 3)

  dispatch  Dispatch  @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
}

model Sale {
  id             String            @id @default(cuid())
  saleNumber     String
  shopId         String
  staffId        String
  customerId     String?
  orderId        String?
  dmId           String?
  isWalkin       Boolean           @default(false)
  subtotal       Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal           @default(0) @db.Decimal(12, 2)
  dueDate        DateTime?
  paymentStatus  BillPaymentStatus @default(UNPAID)
  saleStatus     SaleStatus        @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  cancelledAt    DateTime?
  cancelReason   String?
  customerSignature String?       @db.Text

  shop               Shop                @relation(fields: [shopId], references: [id])
  staff              User                @relation("SaleStaff", fields: [staffId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  deliveryMemo       DeliveryMemo?       @relation(fields: [dmId], references: [id])
  items              SaleItem[]
  dispatches         Dispatch[]
  payments           Payment[]
  creditOutstandings CreditOutstanding[]

  @@unique([shopId, saleNumber])
  @@index([shopId, createdAt])
  @@index([customerId])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  itemId         String
  quantity       Decimal @db.Decimal(12, 3)
  rate           Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model DeliveryMemo {
  id                  String             @id @default(cuid())
  dmNumber            String
  shopId              String
  orderId             String?
  staffId             String
  customerId          String?
  customerName        String
  customerPhone       String?
  customerAddress     String?
  estimatedAmount     Decimal            @default(0) @db.Decimal(12, 2)
  paidAmount          Decimal            @default(0) @db.Decimal(12, 2)
  balanceAmount       Decimal            @default(0) @db.Decimal(12, 2)
  status              DeliveryMemoStatus @default(CREATED)
  paymentStatus       BillPaymentStatus  @default(UNPAID)
  expectedPaymentDate DateTime?
  reason              String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  closedAt            DateTime?

  shop               Shop                @relation(fields: [shopId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  staff              User                @relation("DeliveryMemoStaff", fields: [staffId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  items              DeliveryMemoItem[]
  dispatches         Dispatch[]
  sales              Sale[]
  payments           Payment[]
  creditOutstandings CreditOutstanding[]

  @@unique([shopId, dmNumber])
  @@index([shopId, status])
  @@index([shopId, expectedPaymentDate])
  @@index([customerId])
}

model DeliveryMemoItem {
  id             String  @id @default(cuid())
  dmId           String
  itemId         String
  quantity       Decimal @db.Decimal(12, 3)
  rate           Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  deliveryMemo DeliveryMemo @relation(fields: [dmId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model Payment {
  id                 String        @id @default(cuid())
  shopId             String
  saleId             String?
  dmId               String?
  orderId            String?
  customerId         String?
  paymentMode        PaymentMode
  amount             Decimal       @db.Decimal(12, 2)
  verificationStatus PaymentStatus @default(RECORDED)
  cashSessionId      String?
  receivedById       String
  receivedAt         DateTime      @default(now())
  verifiedById       String?
  verifiedAt         DateTime?
  referenceNumber    String?
  proofImageUrl      String?
  notes              String?
  cancelledAt        DateTime?
  cancelReason       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  shop         Shop           @relation(fields: [shopId], references: [id])
  sale         Sale?          @relation(fields: [saleId], references: [id])
  deliveryMemo DeliveryMemo?  @relation(fields: [dmId], references: [id])
  order        Order?         @relation(fields: [orderId], references: [id])
  customer     Customer?      @relation(fields: [customerId], references: [id])
  cashSession  CashSession?   @relation(fields: [cashSessionId], references: [id])
  receivedBy   User           @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
  verifiedBy   User?          @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id])
  details      PaymentDetail?

  @@index([shopId, receivedAt])
  @@index([paymentMode, verificationStatus])
  @@index([customerId])
  @@index([saleId])
  @@index([dmId])
  @@index([orderId])
}

model PaymentDetail {
  id                 String        @id @default(cuid())
  paymentId          String        @unique
  upiReference       String?
  cardTxnId          String?
  cardLast4          String?
  cardMachineName    String?
  bankUtr            String?
  bankAccount        String?
  senderName         String?
  chequeNumber       String?
  chequeBankName     String?
  chequeBranch       String?
  chequeDate         DateTime?
  chequeReceivedDate DateTime?
  chequeDepositDate  DateTime?
  chequeClearDate    DateTime?
  chequeStatus       ChequeStatus?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model CashSession {
  id                    String            @id @default(cuid())
  shopId                String
  staffId               String
  previousSessionId     String?
  openingCash           Decimal           @default(0) @db.Decimal(12, 2)
  expectedCash          Decimal           @default(0) @db.Decimal(12, 2)
  actualCash            Decimal?          @db.Decimal(12, 2)
  cashHandover          Decimal?          @db.Decimal(12, 2)
  otherDeductionsAmount Decimal?          @db.Decimal(12, 2)
  otherDeductionsReason String?
  difference            Decimal?          @db.Decimal(12, 2)
  differenceReason      String?
  status                CashSessionStatus @default(OPEN)
  openedAt              DateTime          @default(now())
  closedAt              DateTime?
  reviewedById          String?
  reviewedAt            DateTime?

  shop            Shop          @relation(fields: [shopId], references: [id])
  staff           User          @relation("CashSessionStaff", fields: [staffId], references: [id])
  reviewedBy      User?         @relation("CashSessionReviewedBy", fields: [reviewedById], references: [id])
  payments        Payment[]
  previousSession CashSession?  @relation("SessionChain", fields: [previousSessionId], references: [id])
  nextSessions    CashSession[] @relation("SessionChain")

  @@index([shopId, openedAt])
  @@index([previousSessionId])
  @@index([staffId, status])
}

model CreditOutstanding {
  id            String       @id @default(cuid())
  shopId        String
  customerId    String
  saleId        String?
  dmId          String?
  orderId       String?
  pendingAmount Decimal      @db.Decimal(12, 2)
  dueDate       DateTime?
  note          String?
  status        CreditStatus @default(PENDING)
  createdById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  sale         Sale?         @relation(fields: [saleId], references: [id])
  deliveryMemo DeliveryMemo? @relation(fields: [dmId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  createdBy    User          @relation("CreditCreatedBy", fields: [createdById], references: [id])

  @@index([shopId, status])
  @@index([customerId])
  @@index([shopId, dueDate])
}

model RateChangeRequest {
  id             String        @id @default(cuid())
  orderItemId    String
  currentRate    Decimal       @db.Decimal(12, 2)
  suggestedRate  Decimal       @db.Decimal(12, 2)
  reason         String
  requestedById  String
  status         RequestStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  requestedBy User      @relation("RateRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?     @relation("RateApprovedBy", fields: [approvedById], references: [id])

  @@index([orderItemId])
  @@index([status])
}

model CorrectionRequest {
  id                  String        @id @default(cuid())
  entityType          String
  entityId            String
  requestedChangeJson Json
  reason              String
  requestedById       String
  status              RequestStatus @default(PENDING)
  approvedById        String?
  approvedAt          DateTime?
  rejectedReason      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  requestedBy User  @relation("CorrectionRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User? @relation("CorrectionApprovedBy", fields: [approvedById], references: [id])

  @@index([entityType, entityId])
  @@index([status])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  shopId       String
  triggerEvent String
  entityType   String
  entityId     String?
  message      String
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id])

  @@index([userId, isRead])
  @@index([shopId])
}

model AuditLog {
  id           String    @id @default(cuid())
  /// Nullable only for system-generated audit entries. Human-triggered actions must set userId in the service layer.
  userId       String?
  role         RoleName?
  shopId       String?
  action       String
  entityType   String
  entityId     String?
  oldValueJson Json?
  newValueJson Json?
  reason       String?
  deviceInfo   String?
  createdAt    DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt])
  @@index([entityType, entityId])
}

model DailySummary {
  id                     String        @id @default(cuid())
  shopId                 String
  summaryDate            DateTime      @db.Date
  status                 SummaryStatus @default(DRAFT)
  openingCash            Decimal       @default(0) @db.Decimal(12, 2)
  expectedCash           Decimal       @default(0) @db.Decimal(12, 2)
  actualCash             Decimal?      @db.Decimal(12, 2)
  cashDifference         Decimal?      @db.Decimal(12, 2)
  totalSales             Decimal       @default(0) @db.Decimal(12, 2)
  walkinSales            Decimal       @default(0) @db.Decimal(12, 2)
  totalCashCollected     Decimal       @default(0) @db.Decimal(12, 2)
  totalUpiCollected      Decimal       @default(0) @db.Decimal(12, 2)
  totalCardCollected     Decimal       @default(0) @db.Decimal(12, 2)
  totalBankCollected     Decimal       @default(0) @db.Decimal(12, 2)
  totalChequeReceived    Decimal       @default(0) @db.Decimal(12, 2)
  totalCreditPending     Decimal       @default(0) @db.Decimal(12, 2)
  ordersCreatedCount     Int           @default(0)
  ordersDispatchedCount  Int           @default(0)
  salesCount             Int           @default(0)
  dmCreatedCount         Int           @default(0)
  paymentMismatchCount   Int           @default(0)
  correctionRequestCount Int           @default(0)
  rateChangeRequestCount Int           @default(0)
  stockMovementCount     Int           @default(0)
  payloadJson            Json?
  reviewedById           String?
  reviewedAt             DateTime?
  lockedAt               DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  shop       Shop                 @relation(fields: [shopId], references: [id])
  reviewedBy User?                @relation("SummaryReviewedBy", fields: [reviewedById], references: [id])
  exports    DailySummaryExport[]

  @@unique([shopId, summaryDate])
  @@index([summaryDate])
}

model DailySummaryExport {
  id             String       @id @default(cuid())
  dailySummaryId String
  format         ExportFormat
  status         ExportStatus @default(PENDING)
  fileUrl        String?
  errorMsg       String?
  exportedById   String
  exportedAt     DateTime     @default(now())

  dailySummary DailySummary @relation(fields: [dailySummaryId], references: [id], onDelete: Cascade)
  exportedBy   User         @relation(fields: [exportedById], references: [id])

  @@index([dailySummaryId])
}
