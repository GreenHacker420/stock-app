model DailySummaryExport {
  id             String       @id @default(cuid())
  dailySummaryId String
  format         ExportFormat
  status         ExportStatus @default(PENDING)
  fileUrl        String?
  exportedById   String
  exportedAt     DateTime     @default(now())

  dailySummary DailySummary @relation(fields: [dailySummaryId], references: [id], onDelete: Cascade)
  exportedBy   User         @relation(fields: [exportedById], references: [id])

  @@index([dailySummaryId])
}

model StockReservation {
  id             String                    @id @default(cuid())
  shopId         String
  orderId        String
  orderItemId    String
  itemId         String
  reservedQty    Decimal                   @db.Decimal(12, 3)
  packedQty      Decimal                   @default(0) @db.Decimal(12, 3)
  status         ReservationStatus         @default(ACTIVE)
  releasedAt     DateTime?
  releasedReason ReservationReleaseReason?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  shop      Shop      @relation(fields: [shopId], references: [id])
  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])

  @@index([shopId, status])
  @@index([itemId, status])
}

model InventoryReturn {
  id           String           @id @default(cuid())
  returnNumber String           @unique
  shopId       String
  customerId   String
  saleId       String?
  dmId         String?
  sourceType   ReturnSourceType
  netAmount    Decimal          @db.Decimal(12, 2)
  status       ReturnStatus     @default(PENDING)
  notes        String?
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  shop         Shop                  @relation(fields: [shopId], references: [id])
  customer     Customer              @relation(fields: [customerId], references: [id])
  sale         Sale?                 @relation(fields: [saleId], references: [id])
  deliveryMemo DeliveryMemo?         @relation(fields: [dmId], references: [id])
  createdBy    User                  @relation("ReturnCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?                 @relation("ReturnApprovedBy", fields: [approvedById], references: [id])
  items        InventoryReturnItem[]

  @@index([shopId, status])
  @@index([customerId])
}

model InventoryReturnItem {
  id                String  @id @default(cuid())
  inventoryReturnId String
  itemId            String
  quantity          Decimal @db.Decimal(12, 3)
  rate              Decimal @db.Decimal(12, 2)
  totalAmount       Decimal @db.Decimal(12, 2)

  return InventoryReturn @relation(fields: [inventoryReturnId], references: [id], onDelete: Cascade)
  item   Item            @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model Expense {
  id               String          @id @default(cuid())
  shopId           String
  cashSessionId    String?
  amount           Decimal         @db.Decimal(12, 2)
  category         ExpenseCategory
  note             String?
  photoUrl         String?
  status           ExpenseStatus   @default(PENDING)
  verificationNote String?
  verifiedById     String?
  verifiedAt       DateTime?
  createdById      String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  shop        Shop         @relation(fields: [shopId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])
  verifiedBy  User?        @relation("ExpenseVerifiedBy", fields: [verifiedById], references: [id])

  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([cashSessionId])
}

model Attendance {
  id        String           @id @default(cuid())
  shopId    String
  staffId   String
  date      DateTime         @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  shop  Shop @relation(fields: [shopId], references: [id])
  staff User @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([shopId, date])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  staffId      String
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String
  status       LeaveStatus @default(PENDING)
  approvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  staff User @relation(fields: [staffId], references: [id])

  @@index([staffId])
}

// --- WHATSAPP MODELS ---

enum WaMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  DELETED
}

enum WaOperationState {
  QUEUED
  PROCESSING
  RETRY_SCHEDULED
  TERMINALLY_FAILED
  COMPLETED
}

enum WaProviderStatus {
  PENDING
  ACCEPTED
  SENT
  DELIVERED
  READ
  FAILED
}

enum WaContentState {
  VISIBLE
  DELETED
}

enum WaMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  STICKER
  TEMPLATE
  FLOW
  INTERACTIVE
  LOCATION
  CONTACT_CARD
  REACTION
  ORDER
  SYSTEM
  UNSUPPORTED
}

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaIntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WaFlowStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
  BLOCKED
  THROTTLED
}

enum WaFlowExecutionStatus {
  STARTED
  OPENED
  SUBMITTED
  COMPLETED
  CANCELLED
  FAILED
  EXPIRED
}

enum WaTemplateStatus {
  APPROVED
  REJECTED
  PENDING
  PAUSED
  DISABLED
  IN_APPEAL
  DELETED
}

enum WaBroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum WaBroadcastRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum WaMessagingLimitTier {
  TIER_250
  TIER_1K
  TIER_10K
  TIER_100K
  UNLIMITED
}

enum WaQualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

enum WaTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

enum WaTemplateAttributeType {
  TEXT
  NUMBER
  CURRENCY
  DATE
  DATETIME
  BOOLEAN
  URL
  PHONE
  EMAIL
}

enum WaTemplateAttributeSource {
  SYSTEM
  CUSTOMER
  CONVERSATION
  SHOP
  CUSTOM
}

enum WaTemplateMappingStatus {
  VALID
  INCOMPLETE
  INVALID
}

enum AssetKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  OTHER
}

enum AssetStatus {
  UPLOADING
  READY
  FAILED
  DELETED
}

enum AssetSource {
  WHATSAPP_INBOUND
  WHATSAPP_OUTBOUND
  INTERNAL
}

enum AssetStorageProvider {
  S3
}

model Asset {
  id               String                @id @default(cuid())
  shopId           String
  createdById      String?
  kind             AssetKind
  source           AssetSource
  status           AssetStatus           @default(UPLOADING)
  storageProvider  AssetStorageProvider?
  storageBucket    String?
  storageKey       String?
  remoteUrl        String?
  externalProvider String?
  externalId       String?
  mimeType         String
  fileName         String?
  sizeBytes        BigInt?
  checksumSha256   String?
  width            Int?
  height           Int?
  durationMs       Int?
  metadata         Json?
  errorMessage     String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  readyAt          DateTime?
  deletedAt        DateTime?

  shop       Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy  User?       @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  waMessages WaMessage[]

  @@unique([shopId, storageProvider, storageBucket, storageKey])
  @@unique([shopId, externalProvider, externalId])
  @@index([shopId, status, createdAt])
  @@index([createdById])
}

model WaConversation {
  id                    String    @id @default(cuid())
  shopId                String
  customerId            String?
  phone                 String
  bsuid                 String?
  contactName           String?
  lastCustomerMessageAt DateTime?
  unreadCount           Int       @default(0)
  isArchived            Boolean   @default(false)
  isPinned              Boolean   @default(false)
  assignedToId          String?
  entityVersion         Int       @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  shop           Shop              @relation(fields: [shopId], references: [id])
  customer       Customer?         @relation(fields: [customerId], references: [id])
  assignedTo     User?             @relation(fields: [assignedToId], references: [id])
  messages       WaMessage[]
  flowExecutions WaFlowExecution[]

  @@unique([shopId, phone])
  @@index([shopId, updatedAt, id])
  @@index([shopId, customerId])
}

model WaMessage {
  id                   String             @id @default(cuid())
  conversationId       String
  clientMessageId      String?
  clientPayloadHash    String?
  sourceDeviceId       String?
  requestId            String?
  metaMessageId        String?            @unique
  replyToMetaMessageId String?
  direction            WaMessageDirection
  status               WaMessageStatus    @default(QUEUED)
  operationState       WaOperationState   @default(QUEUED)
  providerStatus       WaProviderStatus   @default(PENDING)
  contentState         WaContentState     @default(VISIBLE)
  attempt              Int                @default(1)
  providerStatusAt     DateTime?
  entityVersion        Int                @default(1)
  type                 WaMessageType      @default(TEXT)
  content              Json? // Text content or media metadata
  payload              Json?
  assetId              String?
  templateId           String?
  templateName         String?
  templateLanguage     String?
  broadcastRecipientId String?
  retryCount           Int                @default(0)
  lastRetryAt          DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  failedAt             DateTime?
  errorMessage         String?
  createdAt            DateTime           @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id])
  asset        Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([conversationId, clientMessageId])
  @@index([conversationId, createdAt, id])
  @@index([clientMessageId])
  @@index([operationState, lastRetryAt])
  @@index([assetId])
}

enum WaWebhookEventType {
  STATUS
  MESSAGE
}

enum WaWebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  QUARANTINED
}

model WaWebhookEnvelope {
  id                String                    @id @default(cuid())
  shopId            String
  wabaId            String?
  phoneNumberId     String?
  field             String
  payloadJson       Json
  payloadHash       String
  signatureVerified Boolean                   @default(false)
  processingStatus  WaWebhookProcessingStatus @default(RECEIVED)
  attemptCount      Int                       @default(0)
  errorCode         String?
  errorMessage      String?
  receivedAt        DateTime                  @default(now())
  processedAt       DateTime?

  @@unique([shopId, payloadHash])
  @@index([shopId, processingStatus, receivedAt])
  @@index([field, receivedAt])
}

model WaWebhookEvent {
  id          String             @id // Composite or hash ID
  shopId      String?
  eventType   WaWebhookEventType
  processedAt DateTime           @default(now())

  @@index([processedAt])
}

model WaTemplate {
  id                  String                  @id @default(cuid())
  shopId              String
  metaTemplateId      String?
  name                String
  language            String
  status              WaTemplateStatus        @default(PENDING)
  category            WaTemplateCategory
  components          Json
  headerVariables     Json?
  bodyVariables       Json?
  qualityScore        String?
  sentCount           Int                     @default(0)
  readCount           Int                     @default(0)
  metaRejectionReason String?
  statusUpdatedAt     DateTime?
  qualityUpdatedAt    DateTime?
  syncedAt            DateTime?
  subtype             String?
  parameterFormat     String                  @default("POSITIONAL")
  mappingStatus       WaTemplateMappingStatus @default(INCOMPLETE)
  draftDefinition     Json?
  rawMeta             Json?
  syncError           String?
  deletedAt           DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  shop             Shop                        @relation(fields: [shopId], references: [id])
  broadcasts       WaBroadcast[]
  variableMappings WaTemplateVariableMapping[]
  versions         WaTemplateVersion[]

  @@unique([shopId, name, language])
  @@index([shopId, status])
}

model WaTemplateAttribute {
  id            String                    @id @default(cuid())
  shopId        String
  key           String
  label         String
  type          WaTemplateAttributeType   @default(TEXT)
  source        WaTemplateAttributeSource @default(CUSTOM)
  sourcePath    String?
  fallbackValue String?
  description   String?
  isSystem      Boolean                   @default(false)
  isActive      Boolean                   @default(true)
  createdById   String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  shop      Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy User?                       @relation("WaTemplateAttributeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  mappings  WaTemplateVariableMapping[]

  @@unique([shopId, key])
  @@index([shopId, isActive])
}

model WaTemplateVariableMapping {
  id            String   @id @default(cuid())
  templateId    String
  component     String
  position      Int
  buttonIndex   Int?
  cardIndex     Int?
  attributeId   String?
  sampleValue   String
  fallbackValue String?
  required      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  template  WaTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  attribute WaTemplateAttribute? @relation(fields: [attributeId], references: [id], onDelete: SetNull)

  @@unique([templateId, component, position, buttonIndex, cardIndex])
  @@index([templateId])
  @@index([attributeId])
}

model WaTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  definition  Json
  metaStatus  String?
  createdById String?
  createdAt   DateTime @default(now())

  template  WaTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("WaTemplateVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([templateId, version])
  @@index([templateId, createdAt])
}

model WaTemplateUsage {
  id         String @id @default(cuid())
  templateId String
  sentCount  Int    @default(0)
  readCount  Int    @default(0)
  replyCount Int    @default(0)
}

model WaFlow {
  id               String       @id @default(cuid())
  shopId           String
  flowId           String?
  name             String
  description      String?
  status           WaFlowStatus @default(DRAFT)
  categories       Json?
  flowJson         Json?
  jsonVersion      String?
  dataApiVersion   String?
  validationErrors Json?
  endpointEnabled  Boolean      @default(false)
  endpointKey      String       @unique
  endpointUrl      String?
  endpointHealth   Json?
  handlerKey       String?
  previewUrl       String?
  previewExpiresAt DateTime?
  localRevision    Int          @default(1)
  deployedRevision Int?
  rawMeta          Json?
  syncError        String?
  totalSent        Int          @default(0)
  totalResponses   Int          @default(0)
  syncedAt         DateTime?
  publishedAt      DateTime?
  deprecatedAt     DateTime?
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  shop       Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  executions WaFlowExecution[]

  @@unique([shopId, flowId])
  @@index([shopId, status, updatedAt])
}

model WaFlowExecution {
  id                String                @id @default(cuid())
  shopId            String
  flowId            String
  conversationId    String
  customerId        String?
  metaMessageId     String?
  flowToken         String?               @unique
  flowTokenHash     String?
  idempotencyKey    String?
  status            WaFlowExecutionStatus @default(STARTED)
  currentScreen     String?
  lastAction        String?
  attemptCount      Int                   @default(0)
  lastEndpointError String?
  inputJson         Json?
  resultJson        Json?
  sentAt            DateTime?
  openedAt          DateTime?
  submittedAt       DateTime?
  startedAt         DateTime              @default(now())
  completedAt       DateTime?
  cancelledAt       DateTime?
  expiresAt         DateTime?

  waFlow       WaFlow         @relation(fields: [flowId], references: [id])
  conversation WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?      @relation(fields: [customerId], references: [id])

  @@index([shopId, flowId])
  @@index([flowToken])
  @@index([idempotencyKey])
  @@index([conversationId, startedAt])
}

model WaBroadcast {
  id                String            @id @default(cuid())
  shopId            String
  name              String
  templateId        String?
  templateVariables Json?
  audienceFilter    Json?
  audienceCount     Int               @default(0)
  status            WaBroadcastStatus @default(DRAFT)
  sentCount         Int               @default(0)
  deliveredCount    Int               @default(0)
  readCount         Int               @default(0)
  failedCount       Int               @default(0)
  skippedCount      Int               @default(0)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdById       String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shop       Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  template   WaTemplate?            @relation(fields: [templateId], references: [id])
  createdBy  User                   @relation(fields: [createdById], references: [id])
  recipients WaBroadcastRecipient[]

  @@index([shopId, status])
}

model WaBroadcastRecipient {
  id            String                     @id @default(cuid())
  broadcastId   String
  customerId    String
  customerName  String?
  customerPhone String
  status        WaBroadcastRecipientStatus @default(PENDING)
  metaMessageId String?
  errorMessage  String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime                   @default(now())

  broadcast WaBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  customer  Customer    @relation(fields: [customerId], references: [id])

  @@unique([broadcastId, customerId])
  @@index([broadcastId, status])
}

model SaleAmendment {
  id               String   @id @default(cuid())
  saleId           String
  version          Int
  previousSubtotal Decimal  @db.Decimal(12, 2)
  newSubtotal      Decimal  @db.Decimal(12, 2)
  previousTotal    Decimal  @db.Decimal(12, 2)
  newTotal         Decimal  @db.Decimal(12, 2)
  reason           String
  createdById      String
  createdAt        DateTime @default(now())
  beforeSnapshot   Json
  afterSnapshot    Json
  stockDelta       Json
  financialDelta   Json

  sale      Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy User @relation("AmendmentCreator", fields: [createdById], references: [id])

  @@index([saleId])
}

model Invoice {
  id             String        @id @default(cuid())
  saleId         String
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  saleSnapshot   Json
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @db.Decimal(12, 2)
  taxableAmount  Decimal       @db.Decimal(12, 2)
  cgstAmount     Decimal       @db.Decimal(12, 2)
  sgstAmount     Decimal       @db.Decimal(12, 2)
  igstAmount     Decimal       @db.Decimal(12, 2)
  grandTotal     Decimal       @db.Decimal(12, 2)
  version        Int           @default(1)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@index([saleId])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}
