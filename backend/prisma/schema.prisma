generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum RoleName {
  OWNER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PACKING
  PARTIALLY_PACKED
  PACKED
  PARTIALLY_DISPATCHED
  DISPATCHED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  AVAILABLE
  PACKED
  PARTIALLY_PACKED
  SHORTAGE
  DISPATCHED
  RETURNED
  CANCELLED
}

enum PackingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIALLY_COMPLETED
  CANCELLED
}

enum DispatchStatus {
  CREATED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
  RETURNED
}

enum DeliveryMemoStatus {
  CREATED
  PARTIALLY_PAID
  FULLY_PAID
  CONVERTED_TO_SALE
  RETURNED
  CANCELLED
  OVERDUE
}

enum DeliveryMemoPurpose {
  CREDIT_DELIVERY
  SUPPLY_PENDING_INVOICE
  GOODS_ON_APPROVAL
  JOB_WORK
  STOCK_TRANSFER
  WARRANTY_REPLACEMENT
  DEMO_OR_SAMPLE
}

enum DeliveryMemoLifecycleStatus {
  DRAFT
  READY_TO_DISPATCH
  DISPATCHED
  CANCELLATION_PENDING
  CANCELLED
  CLOSED
}

enum DeliveryMemoInvoicingStatus {
  NOT_INVOICED
  PARTIALLY_INVOICED
  FULLY_INVOICED
}

enum DeliveryMemoReturnStatus {
  NO_RETURN
  PARTIALLY_RETURNED
  FULLY_RETURNED
}

enum CustomerLedgerDirection {
  DEBIT
  CREDIT
}

enum SerialAssignmentStatus {
  ACTIVE
  RELEASED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
}

enum PaymentStatus {
  RECORDED
  VERIFIED
  REJECTED
  CANCELLED
}

enum BillPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum ChequeStatus {
  RECEIVED
  DEPOSITED
  CLEARED
  BOUNCED
  RETURNED
  CANCELLED
}

enum StockMovementType {
  OPENING_STOCK
  STOCK_IN
  STOCK_OUT
  SALE
  DM
  ORDER_DISPATCH
  RETURN
  DAMAGE_LOSS
  MANUAL_ADJUSTMENT
}

enum CashSessionStatus {
  OPEN
  CLOSED
  REVIEWED
  LOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalType {
  STOCK_ENTRY
  STOCK_ADJUSTMENT
  DAMAGE_ENTRY
  RATE_CHANGE
  SALE_CORRECTION
  SALE_CANCELLATION
  DM_CANCELLATION
  PAYMENT_CORRECTION
}

enum ExpenseCategory {
  FREIGHT
  COURIER
  PORTER
  TEA
  SNACKS
  TEA_SNACKS
  PETROL
  PACKAGING
  LABOUR
  ELECTRICITY
  INTERNET
  MISC
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GstInvoiceStatus {
  NOT_REQUIRED
  PENDING
  GENERATED
}

enum SummaryStatus {
  DRAFT
  GENERATED
  REVIEWED
  LOCKED
  EXPORTED
}

enum ExportFormat {
  PDF
  CSV
}

enum ExportStatus {
  PENDING
  DONE
  FAILED
}

enum ReturnSourceType {
  SALE
  DELIVERY_MEMO
}

enum ReservationStatus {
  ACTIVE
  DISPATCHED
  CANCELLED
}

enum ReturnStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum ReservationReleaseReason {
  DISPATCH
  CANCEL
  SHORTAGE
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PriceType {
  SELLING
  MINIMUM
  MRP
  PURCHASE
}

enum EntityType {
  USER
  SHOP
  CUSTOMER
  ITEM
  STOCK_LEDGER
  ORDER
  SALE
  DELIVERY_MEMO
  PAYMENT
  CASH_SESSION
  APPROVAL_REQUEST
  INVENTORY_RETURN
  EXPENSE
  STAFF_SHOP_ACCESS
  STOCK_BALANCE
  STOCK_RESERVATION
  WHATSAPP
  WHATSAPP_BROADCAST
}

enum NotificationEvent {
  ORDER_ASSIGNED
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  CHEQUE_BOUNCED
  LOW_STOCK
  PAYMENT_MISMATCH
  WHATSAPP_DLQ
  WHATSAPP_MESSAGE
  TEST_NOTIFICATION
}

enum OrderEventType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_ASSIGNED
  PACKING_STARTED
  ITEM_PACKED
  SHORTAGE_REPORTED
  PAYMENT_ADDED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  MOVEMENT_CREATED
  ENTRY_REQUESTED
  OPENING_SET
  WALKIN_CREATED
  REVIEWED
  CANCELLED
  VOIDED
  APPROVED
  REJECTED
  COMPLETED
  SUBMITTED
  DEPOSITED
  CLEARED
  BOUNCED
  RETURNED
  STAFF_ASSIGNED
}

enum CustomerType {
  WALK_IN
  REGULAR
  BUSINESS
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum WaOnboardingStatus {
  CREATED
  AUTHORIZED
  ASSETS_DISCOVERED
  APP_SUBSCRIBED
  NUMBER_REGISTERED
  CONNECTED
  ACTION_REQUIRED
  FAILED
  CANCELLED
  EXPIRED
}

enum WaOnboardingMode {
  CLOUD_API
  COEXISTENCE
}

enum PushDeliveryStatus {
  PENDING
  SENT
  FAILED
}

// --- MODELS ---

model User {
  id           String     @id @default(cuid())
  name         String
  mobile       String     @unique
  email        String?    @unique
  passwordHash String
  role         RoleName   @default(STAFF)
  status       UserStatus @default(ACTIVE)
  staffOwnerId String?
  pushToken    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ownedShops             Shop[]                         @relation("ShopOwner")
  staffOwner             User?                          @relation("StaffOwner", fields: [staffOwnerId], references: [id], onDelete: SetNull)
  ownedStaff             User[]                         @relation("StaffOwner")
  staffShopAccesses      StaffShopAccess[]
  customersCreated       Customer[]                     @relation("CustomerCreatedBy")
  stockMovementsCreated  StockLedger[]                  @relation("StockCreatedBy")
  stockMovementsApproved StockLedger[]                  @relation("StockApprovedBy")
  ordersCreated          Order[]                        @relation("OrderCreatedBy")
  ordersAssigned         Order[]                        @relation("OrderAssignedStaff")
  orderEvents            OrderEvent[]
  packingTasks           PackingTask[]
  dispatches             Dispatch[]                     @relation("DispatchBy")
  sales                  Sale[]                         @relation("SaleStaff")
  deliveryMemos          DeliveryMemo[]                 @relation("DeliveryMemoStaff")
  paymentsReceived       Payment[]                      @relation("PaymentReceivedBy")
  paymentsVerified       Payment[]                      @relation("PaymentVerifiedBy")
  cashSessions           CashSession[]                  @relation("CashSessionStaff")
  cashSessionsReviewed   CashSession[]                  @relation("CashSessionReviewedBy")
  approvalRequests       ApprovalRequest[]              @relation("ApprovalRequestedBy")
  approvalResponses      ApprovalRequest[]              @relation("ApprovalApprovedBy")
  notifications          Notification[]
  auditLogs              AuditLog[]
  dailySummariesReviewed DailySummary[]                 @relation("SummaryReviewedBy")
  dailySummaryExports    DailySummaryExport[]
  returnsCreated         InventoryReturn[]              @relation("ReturnCreatedBy")
  returnsApproved        InventoryReturn[]              @relation("ReturnApprovedBy")
  dmSerialAssignments    DeliveryMemoSerialAssignment[]
  customerLedgerEntries  CustomerLedgerEntry[]
  expensesCreated        Expense[]
  expensesVerified       Expense[]                      @relation("ExpenseVerifiedBy")
  amendmentsCreated      SaleAmendment[]                @relation("AmendmentCreator")
  priceChanges           ItemPriceHistory[]
  attendance             Attendance[]
  leaveRequests          LeaveRequest[]

  assignedWaConversations     WaConversation[]
  waBroadcasts                WaBroadcast[]
  assetsCreated               Asset[]               @relation("AssetCreatedBy")
  waTemplateAttributesCreated WaTemplateAttribute[] @relation("WaTemplateAttributeCreatedBy")
  waTemplateVersionsCreated   WaTemplateVersion[]   @relation("WaTemplateVersionCreatedBy")
  devices                     UserDevice[]
  waOnboardingSessions        WaOnboardingSession[]

  @@index([staffOwnerId])
}

model UserDevice {
  id                   String         @id @default(cuid())
  userId               String
  installationId       String
  platform             DevicePlatform
  pushToken            String?
  nativePushToken      String?
  voipToken            String?
  appVersion           String?
  buildVersion         String?
  deviceName           String?
  osVersion            String?
  notificationsEnabled Boolean        @default(false)
  voipEnabled          Boolean        @default(false)
  lastShopId           String?
  lastSeenAt           DateTime       @default(now())
  revokedAt            DateTime?
  pushDisabledAt       DateTime?
  lastPushError        String?
  metadata             Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushDeliveries NotificationPushDelivery[]

  @@unique([userId, installationId])
  @@index([userId, revokedAt, lastSeenAt])
  @@index([pushToken])
  @@index([nativePushToken])
  @@index([voipToken])
}

model Shop {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  city      String
  address   String?
  phone     String?
  email     String?
  gstin     String?
  logo      String?
  ownerId   String
  upiId     String?
  upiName   String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  owner                 User                           @relation("ShopOwner", fields: [ownerId], references: [id])
  staffAccesses         StaffShopAccess[]
  customers             Customer[]
  itemCategories        ItemCategory[]
  itemBrands            ItemBrand[]
  items                 Item[]
  stockLedger           StockLedger[]
  stockBalances         StockBalance[]
  orders                Order[]
  packingTasks          PackingTask[]
  dispatches            Dispatch[]
  sales                 Sale[]
  deliveryMemos         DeliveryMemo[]
  payments              Payment[]
  cashSessions          CashSession[]
  notifications         Notification[]
  dailySummaries        DailySummary[]
  reservations          StockReservation[]
  inventoryReturns      InventoryReturn[]
  expenses              Expense[]
  approvalRequests      ApprovalRequest[]
  attendance            Attendance[]
  dmSerialAssignments   DeliveryMemoSerialAssignment[]
  customerLedgerEntries CustomerLedgerEntry[]

  waConversations      WaConversation[]
  waTemplates          WaTemplate[]
  waFlows              WaFlow[]
  waIntegration        WaIntegration?
  waBroadcasts         WaBroadcast[]
  assets               Asset[]
  waTemplateAttributes WaTemplateAttribute[]
  waOnboardingSessions WaOnboardingSession[]

  @@index([ownerId])
}

model WaIntegration {
  id                       String                @id @default(cuid())
  shopId                   String                @unique
  verifyToken              String
  accessToken              String
  appSecret                String?
  businessAccountId        String
  phoneNumberId            String
  phoneNumber              String?
  businessName             String?
  status                   WaIntegrationStatus   @default(DISCONNECTED)
  accountStatus            String?
  accountReviewStatus      String?
  displayNameStatus        String?
  capabilities             Json?
  messagingLimitTier       WaMessagingLimitTier?
  qualityRating            WaQualityRating?
  callingEnabled           Boolean               @default(false)
  rsaPublicKey             String?               @db.Text
  rsaPrivateKeyEncrypted   String?               @db.Text
  connectedAt              DateTime?
  lastWebhookAt            DateTime?
  lastManagementEventAt    DateTime?
  lastManagementEventField String?
  businessPortfolioId      String?
  tokenType                String?
  tokenExpiresAt           DateTime?
  grantedScopes            Json?
  tokenLastValidatedAt     DateTime?
  onboardingMode           WaOnboardingMode?
  reauthorizationRequired  Boolean               @default(false)
  disconnectedAt           DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([phoneNumberId])
}

model WaOnboardingSession {
  id                       String             @id @default(cuid())
  shopId                   String
  initiatedById            String
  status                   WaOnboardingStatus @default(CREATED)
  mode                     WaOnboardingMode   @default(CLOUD_API)
  configId                 String
  graphVersion             String             @default("v25.0")
  stateNonceHash           String
  businessTokenEncrypted   String?            @db.Text
  tokenType                String?
  tokenExpiresAt           DateTime?
  grantedScopes            Json?
  businessPortfolioId      String?
  wabaId                   String?
  phoneNumberId            String?
  finishEvent              String?
  currentStep              String?
  metaSessionId            String?
  sessionInfo              Json?
  completedSteps           Json?
  verifyToken              String?
  registrationPinEncrypted String?
  retryCount               Int                @default(0)
  lastErrorCode            String?
  lastErrorMessage         String?
  lastAttemptAt            DateTime?
  authorizedAt             DateTime?
  subscribedAt             DateTime?
  registeredAt             DateTime?
  connectedAt              DateTime?
  cancelledAt              DateTime?
  expiresAt                DateTime
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  shop        Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  initiatedBy User @relation(fields: [initiatedById], references: [id], onDelete: Cascade)

  @@index([shopId, status, createdAt])
  @@index([initiatedById, createdAt])
  @@index([expiresAt])
}

model StaffShopAccess {
  id        String   @id @default(cuid())
  staffId   String
  shopId    String
  createdAt DateTime @default(now())

  staff User @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shop  Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([staffId, shopId])
  @@index([shopId])
}

model Customer {
  id                String       @id @default(cuid())
  shopId            String
  name              String
  type              CustomerType @default(REGULAR)
  phone             String?
  email             String?
  address           String?
  city              String?
  gstin             String?
  contactPerson     String?
  creditLimit       Decimal?     @db.Decimal(12, 2)
  outstandingAmount Decimal      @default(0) @db.Decimal(12, 2)
  advanceBalance    Decimal      @default(0) @db.Decimal(12, 2)
  notes             String?
  status            RecordStatus @default(ACTIVE)
  createdById       String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  shop                  Shop                   @relation(fields: [shopId], references: [id], onDelete: Restrict)
  createdBy             User                   @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  orders                Order[]
  dispatches            Dispatch[]
  sales                 Sale[]
  deliveryMemos         DeliveryMemo[]
  payments              Payment[]
  inventoryReturns      InventoryReturn[]
  waConversations       WaConversation[]
  waFlowExecutions      WaFlowExecution[]
  waBroadcastRecipients WaBroadcastRecipient[]
  ledgerEntries         CustomerLedgerEntry[]

  @@index([shopId])
  @@index([shopId, status, createdAt])
  @@index([phone])
  @@index([shopId, phone])
  @@index([shopId, gstin])
  @@index([shopId, email])
}

model ItemCategory {
  id        String       @id @default(cuid())
  shopId    String
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop  Shop   @relation(fields: [shopId], references: [id])
  items Item[]

  @@unique([shopId, name])
}

model ItemBrand {
  id        String       @id @default(cuid())
  shopId    String
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop  Shop   @relation(fields: [shopId], references: [id])
  items Item[]

  @@unique([shopId, name])
}

model Item {
  id                   String                      @id @default(cuid())
  shopId               String
  name                 String
  sku                  String?
  categoryId           String?
  brandId              String?
  unit                 String
  defaultSellingPrice  Decimal                     @default(0) @db.Decimal(12, 2)
  minimumAllowedPrice  Decimal?                    @db.Decimal(12, 2)
  purchasePrice        Decimal?                    @db.Decimal(12, 2)
  mrp                  Decimal?                    @db.Decimal(12, 2)
  minimumStock         Decimal                     @default(0) @db.Decimal(12, 3)
  imageUrl             String?
  requiresSerialNumber Boolean                     @default(false)
  status               RecordStatus                @default(ACTIVE)
  embedding            Unsupported("vector(384)")?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  shop                 Shop                           @relation(fields: [shopId], references: [id])
  category             ItemCategory?                  @relation(fields: [categoryId], references: [id])
  brand                ItemBrand?                     @relation(fields: [brandId], references: [id])
  stockLedger          StockLedger[]
  stockBalance         StockBalance?
  orderItems           OrderItem[]
  dispatchItems        DispatchItem[]
  saleItems            SaleItem[]
  deliveryMemoItems    DeliveryMemoItem[]
  reservations         StockReservation[]
  inventoryReturnItems InventoryReturnItem[]
  priceHistory         ItemPriceHistory[]
  bundleComponents     ItemBundleComponent[]          @relation("BundleParent")
  usedInBundles        ItemBundleComponent[]          @relation("BundleComponent")
  dmSerialAssignments  DeliveryMemoSerialAssignment[]

  @@unique([shopId, sku])
  @@index([shopId, name])
  @@index([shopId, status])
  @@index([shopId, sku])
}

model ItemBundleComponent {
  id              String   @id @default(cuid())
  parentItemId    String
  componentItemId String
  quantity        Decimal  @db.Decimal(12, 3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parentItem    Item @relation("BundleParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  componentItem Item @relation("BundleComponent", fields: [componentItemId], references: [id], onDelete: Restrict)

  @@unique([parentItemId, componentItemId])
  @@index([componentItemId])
}

model StockBalance {
  id             String   @id @default(cuid())
  shopId         String
  itemId         String   @unique
  physicalStock  Decimal  @default(0) @db.Decimal(12, 3)
  reservedStock  Decimal  @default(0) @db.Decimal(12, 3)
  availableStock Decimal  @default(0) @db.Decimal(12, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Restrict)
  item Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([shopId])
  @@index([shopId, availableStock])
}

model ItemPriceHistory {
  id          String    @id @default(cuid())
  itemId      String
  oldPrice    Decimal   @db.Decimal(12, 2)
  newPrice    Decimal   @db.Decimal(12, 2)
  priceType   PriceType
  changedById String
  createdAt   DateTime  @default(now())

  item      Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  changedBy User @relation(fields: [changedById], references: [id])

  @@index([itemId])
  @@index([createdAt])
}

model StockLedger {
  id            String            @id @default(cuid())
  shopId        String
  itemId        String
  movementType  StockMovementType
  quantityIn    Decimal           @default(0) @db.Decimal(12, 3)
  quantityOut   Decimal           @default(0) @db.Decimal(12, 3)
  referenceType String?
  referenceId   String?
  reason        String?
  createdById   String
  approvedById  String?
  createdAt     DateTime          @default(now())

  shop       Shop  @relation(fields: [shopId], references: [id], onDelete: Restrict)
  item       Item  @relation(fields: [itemId], references: [id])
  createdBy  User  @relation("StockCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("StockApprovedBy", fields: [approvedById], references: [id])

  @@index([shopId, itemId])
  @@index([shopId, itemId, createdAt])
  @@index([referenceType, referenceId])
}

model Order {
  id                   String            @id @default(cuid())
  orderNumber          String
  shopId               String
  customerId           String
  createdById          String
  assignedStaffId      String?
  orderDate            DateTime          @default(now())
  expectedDispatchDate DateTime?
  priority             Priority          @default(NORMAL)
  status               OrderStatus       @default(DRAFT)
  paymentStatus        BillPaymentStatus @default(UNPAID)
  subtotal             Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount       Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount           Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount        Decimal           @default(0) @db.Decimal(12, 2)
  ownerNotes           String?
  staffNotes           String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  cancelledAt          DateTime?
  cancelReason         String?

  shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customer      Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy     User               @relation("OrderCreatedBy", fields: [createdById], references: [id])
  assignedStaff User?              @relation("OrderAssignedStaff", fields: [assignedStaffId], references: [id])
  items         OrderItem[]
  events        OrderEvent[]
  packingTasks  PackingTask[]
  dispatches    Dispatch[]
  sales         Sale[]
  deliveryMemos DeliveryMemo[]
  payments      Payment[]
  reservations  StockReservation[]

  @@unique([shopId, orderNumber])
  @@index([shopId, status])
  @@index([shopId, status, createdAt])
  @@index([customerId])
}

model OrderItem {
  id                 String          @id @default(cuid())
  orderId            String
  itemId             String
  quantityOrdered    Decimal         @db.Decimal(12, 3)
  quantityPacked     Decimal         @default(0) @db.Decimal(12, 3)
  quantityDispatched Decimal         @default(0) @db.Decimal(12, 3)
  quantityPending    Decimal         @default(0) @db.Decimal(12, 3)
  rate               Decimal         @db.Decimal(12, 2)
  discountAmount     Decimal         @default(0) @db.Decimal(12, 2)
  lineTotal          Decimal         @db.Decimal(12, 2)
  status             OrderItemStatus @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item              Item               @relation(fields: [itemId], references: [id])
  dispatchItems     DispatchItem[]
  reservations      StockReservation[]
  deliveryMemoItems DeliveryMemoItem[]

  @@index([orderId])
  @@index([itemId])
}

model OrderEvent {
  id          String         @id @default(cuid())
  orderId     String
  eventType   OrderEventType
  oldStatus   OrderStatus?
  newStatus   OrderStatus?
  note        String?
  createdById String
  createdAt   DateTime       @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([orderId])
}

model PackingTask {
  id          String        @id @default(cuid())
  orderId     String
  shopId      String
  staffId     String
  status      PackingStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  shop  Shop  @relation(fields: [shopId], references: [id])
  staff User  @relation(fields: [staffId], references: [id])

  @@index([orderId])
  @@index([shopId, status])
  @@index([staffId])
}

model Dispatch {
  id             String         @id @default(cuid())
  orderId        String?
  dmId           String?
  saleId         String?
  customerId     String
  shopId         String
  dispatchedById String
  dispatchDate   DateTime       @default(now())
  status         DispatchStatus @default(CREATED)
  proofImageUrl  String?
  notes          String?
  createdAt      DateTime       @default(now())

  order        Order?         @relation(fields: [orderId], references: [id])
  deliveryMemo DeliveryMemo?  @relation(fields: [dmId], references: [id])
  sale         Sale?          @relation(fields: [saleId], references: [id])
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shop         Shop           @relation(fields: [shopId], references: [id])
  dispatchedBy User           @relation("DispatchBy", fields: [dispatchedById], references: [id])
  items        DispatchItem[]

  @@index([shopId, dispatchDate])
}

model DispatchItem {
  id                 String  @id @default(cuid())
  dispatchId         String
  orderItemId        String
  itemId             String
  quantityDispatched Decimal @db.Decimal(12, 3)

  dispatch  Dispatch  @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
}

model Sale {
  id                    String            @id @default(cuid())
  saleNumber            String
  shopId                String
  staffId               String
  customerId            String
  orderId               String?
  dmId                  String?
  isWalkin              Boolean           @default(false)
  gstRequired           Boolean           @default(false)
  gstInvoiceStatus      GstInvoiceStatus  @default(NOT_REQUIRED)
  gstInvoiceNumber      String?
  gstInvoiceGeneratedAt DateTime?
  subtotal              Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount        Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount            Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount         Decimal           @default(0) @db.Decimal(12, 2)
  paymentStatus         BillPaymentStatus @default(UNPAID)
  saleStatus            SaleStatus        @default(DRAFT)
  customerSignature     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  cancelledAt           DateTime?
  cancelReason          String?
  version               Int               @default(1)

  shop              Shop                           @relation(fields: [shopId], references: [id], onDelete: Restrict)
  amendments        SaleAmendment[]
  invoices          Invoice[]
  staff             User                           @relation("SaleStaff", fields: [staffId], references: [id])
  customer          Customer                       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order             Order?                         @relation(fields: [orderId], references: [id])
  deliveryMemo      DeliveryMemo?                  @relation(fields: [dmId], references: [id])
  items             SaleItem[]
  dispatches        Dispatch[]
  payments          Payment[]
  inventoryReturns  InventoryReturn[]
  serialAssignments DeliveryMemoSerialAssignment[]

  @@unique([shopId, saleNumber])
  @@index([shopId, createdAt])
  @@index([shopId, customerId, createdAt])
  @@index([customerId])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  itemId         String
  quantity       Decimal @db.Decimal(12, 3)
  rate           Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)
  serialNumbers  Json?
  description    String?

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model DeliveryMemo {
  id                  String                      @id @default(cuid())
  dmNumber            String
  shopId              String
  orderId             String?
  staffId             String
  customerId          String
  estimatedAmount     Decimal                     @default(0) @db.Decimal(12, 2)
  paidAmount          Decimal                     @default(0) @db.Decimal(12, 2)
  balanceAmount       Decimal                     @default(0) @db.Decimal(12, 2)
  status              DeliveryMemoStatus          @default(CREATED)
  paymentStatus       BillPaymentStatus           @default(UNPAID)
  expectedPaymentDate DateTime?
  documentPurpose     DeliveryMemoPurpose         @default(CREDIT_DELIVERY)
  lifecycleStatus     DeliveryMemoLifecycleStatus @default(DISPATCHED)
  invoicingStatus     DeliveryMemoInvoicingStatus @default(NOT_INVOICED)
  returnStatus        DeliveryMemoReturnStatus    @default(NO_RETURN)
  postedAt            DateTime?
  deliveryNotes       String?
  version             Int                         @default(1)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  shop                          Shop                           @relation(fields: [shopId], references: [id], onDelete: Restrict)
  order                         Order?                         @relation(fields: [orderId], references: [id])
  staff                         User                           @relation("DeliveryMemoStaff", fields: [staffId], references: [id])
  customer                      Customer                       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items                         DeliveryMemoItem[]
  dispatches                    Dispatch[]
  sales                         Sale[]
  payments                      Payment[]
  inventoryReturns              InventoryReturn[]
  deliveryMemoSerialAssignments DeliveryMemoSerialAssignment[]

  @@unique([shopId, dmNumber])
  @@index([shopId, status])
  @@index([customerId])
}

model DeliveryMemoItem {
  id             String  @id @default(cuid())
  dmId           String
  itemId         String
  orderItemId    String?
  quantity       Decimal @db.Decimal(12, 3)
  returnedQty    Decimal @default(0) @db.Decimal(12, 3)
  rate           Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)
  serialNumbers  Json?
  description    String?

  deliveryMemo DeliveryMemo @relation(fields: [dmId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])
  orderItem    OrderItem?   @relation(fields: [orderItemId], references: [id])

  @@index([itemId])
  @@index([orderItemId])
}

model DeliveryMemoSerialAssignment {
  id            String                 @id @default(cuid())
  shopId        String
  dmId          String
  itemId        String
  serialNumber  String
  status        SerialAssignmentStatus @default(ACTIVE)
  activeKey     String?                @unique
  assignedById  String
  assignedAt    DateTime               @default(now())
  releasedAt    DateTime?
  releaseReason String?

  shop         Shop         @relation(fields: [shopId], references: [id], onDelete: Restrict)
  deliveryMemo DeliveryMemo @relation(fields: [dmId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  assignedBy   User         @relation(fields: [assignedById], references: [id], onDelete: Restrict)
  sale         Sale?        @relation(fields: [saleId], references: [id])
  saleId       String?

  @@index([shopId, itemId, serialNumber])
  @@index([dmId, status])
}

model CustomerLedgerEntry {
  id             String                  @id @default(cuid())
  shopId         String
  customerId     String
  sourceType     String
  sourceId       String
  entryType      String
  direction      CustomerLedgerDirection
  amount         Decimal                 @db.Decimal(12, 2)
  createdById    String
  reversalOfId   String?
  idempotencyKey String?
  notes          String?
  effectiveAt    DateTime                @default(now())
  createdAt      DateTime                @default(now())

  shop       Shop                  @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customer   Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy  User                  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  reversalOf CustomerLedgerEntry?  @relation("CustomerLedgerReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversals  CustomerLedgerEntry[] @relation("CustomerLedgerReversal")

  @@unique([sourceType, sourceId, entryType])
  @@index([shopId, customerId, effectiveAt])
  @@index([reversalOfId])
}

model Payment {
  id              String        @id @default(cuid())
  shopId          String
  saleId          String?
  dmId            String?
  orderId         String?
  customerId      String
  paymentMode     PaymentMode
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(RECORDED)
  cashSessionId   String?
  receivedById    String
  receivedAt      DateTime      @default(now())
  verifiedById    String?
  verifiedAt      DateTime?
  referenceNumber String?
  proofImageUrl   String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shop         Shop           @relation(fields: [shopId], references: [id], onDelete: Restrict)
  sale         Sale?          @relation(fields: [saleId], references: [id], onDelete: Restrict)
  deliveryMemo DeliveryMemo?  @relation(fields: [dmId], references: [id], onDelete: Restrict)
  order        Order?         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashSession  CashSession?   @relation(fields: [cashSessionId], references: [id])
  receivedBy   User           @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
  verifiedBy   User?          @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id])
  details      PaymentDetail?

  @@index([shopId, receivedAt])
  @@index([shopId, createdAt])
  @@index([customerId])
  @@index([saleId])
}

model PaymentDetail {
  id             String        @id @default(cuid())
  paymentId      String        @unique
  upiReference   String?
  bankUtr        String?
  chequeNumber   String?
  chequeBankName String?
  chequeDate     DateTime?
  chequeStatus   ChequeStatus?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model CashSession {
  id                String            @id @default(cuid())
  shopId            String
  staffId           String
  previousSessionId String?
  openingCash       Decimal           @default(0) @db.Decimal(12, 2)
  expectedCash      Decimal           @default(0) @db.Decimal(12, 2)
  actualCash        Decimal?          @db.Decimal(12, 2)
  cashHandover      Decimal?          @db.Decimal(12, 2)
  difference        Decimal?          @db.Decimal(12, 2)
  differenceReason  String?
  status            CashSessionStatus @default(OPEN)
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  reviewedById      String?
  reviewedAt        DateTime?

  shop            Shop          @relation(fields: [shopId], references: [id])
  staff           User          @relation("CashSessionStaff", fields: [staffId], references: [id])
  reviewedBy      User?         @relation("CashSessionReviewedBy", fields: [reviewedById], references: [id])
  payments        Payment[]
  expenses        Expense[]
  previousSession CashSession?  @relation("SessionChain", fields: [previousSessionId], references: [id])
  nextSessions    CashSession[] @relation("SessionChain")

  @@index([shopId, openedAt])
  @@index([staffId, status])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String
  shopId       String
  userId       String
  endpoint     String
  requestHash  String
  responseJson Json?
  statusCode   Int?
  resourceType String?
  resourceId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([key, shopId, userId, endpoint])
  @@index([shopId, endpoint, createdAt])
  @@index([resourceType, resourceId])
}

model DomainEventOutbox {
  id          String    @id
  tenantId    String?
  shopId      String
  entity      String
  action      String
  entityId    String
  eventJson   Json
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  sequence    BigInt
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@unique([shopId, sequence])
  @@index([status, createdAt])
  @@index([shopId, entity, action])
  @@index([entity, entityId])
  @@index([shopId, status, sequence])
}

model ShopEventSequence {
  shopId String @id
  value  BigInt @default(0)
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  shopId         String
  type           ApprovalType
  entityType     EntityType
  entityId       String
  payloadJson    Json
  reason         String
  requestedById  String
  status         ApprovalStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  shop        Shop  @relation(fields: [shopId], references: [id])
  requestedBy User  @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User? @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])

  @@index([shopId, status])
  @@index([entityType, entityId])
}

model Notification {
  id            String            @id @default(cuid())
  userId        String
  shopId        String
  triggerEvent  NotificationEvent
  entityType    EntityType
  entityId      String?
  message       String
  isRead        Boolean           @default(false)
  createdAt     DateTime          @default(now())
  domainEventId String?

  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop           Shop                       @relation(fields: [shopId], references: [id])
  pushDeliveries NotificationPushDelivery[]

  @@unique([domainEventId, userId])
  @@index([userId, isRead])
  @@index([userId, isRead, createdAt])
  @@index([shopId])
}

model NotificationPushDelivery {
  id             String             @id @default(cuid())
  notificationId String
  deviceId       String
  status         PushDeliveryStatus @default(PENDING)
  provider       String             @default("EXPO")
  ticketId       String?
  attemptCount   Int                @default(0)
  errorCode      String?
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  device       UserDevice   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([notificationId, deviceId])
  @@index([status, createdAt])
  @@index([deviceId, createdAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  shopId       String?
  action       AuditAction
  entityType   EntityType
  entityId     String?
  oldValueJson Json?
  newValueJson Json?
  reason       String?
  createdAt    DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt])
  @@index([entityType, entityId])
}

model DailySummary {
  id                 String        @id @default(cuid())
  shopId             String
  summaryDate        DateTime      @db.Date
  status             SummaryStatus @default(DRAFT)
  openingCash        Decimal       @default(0) @db.Decimal(12, 2)
  expectedCash       Decimal       @default(0) @db.Decimal(12, 2)
  actualCash         Decimal?      @db.Decimal(12, 2)
  cashDifference     Decimal?      @db.Decimal(12, 2)
  totalSales         Decimal       @default(0) @db.Decimal(12, 2)
  walkinSales        Decimal       @default(0) @db.Decimal(12, 2)
  totalCashCollected Decimal       @default(0) @db.Decimal(12, 2)
  totalUpiCollected  Decimal       @default(0) @db.Decimal(12, 2)
  totalBankCollected Decimal       @default(0) @db.Decimal(12, 2)
  totalCreditPending Decimal       @default(0) @db.Decimal(12, 2)
  ordersCreatedCount Int           @default(0)
  salesCount         Int           @default(0)
  dmCreatedCount     Int           @default(0)
  expenseCount       Int           @default(0)
  payloadJson        Json?
