generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum RoleName {
  OWNER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PACKING
  PARTIALLY_PACKED
  PACKED
  DISPATCHED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  AVAILABLE
  PACKED
  PARTIALLY_PACKED
  SHORTAGE
  DISPATCHED
  RETURNED
  CANCELLED
}

enum PackingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIALLY_COMPLETED
  CANCELLED
}

enum DispatchStatus {
  CREATED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
  RETURNED
}

enum DeliveryMemoStatus {
  CREATED
  PARTIALLY_PAID
  FULLY_PAID
  CONVERTED_TO_SALE
  RETURNED
  CANCELLED
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
}

enum PaymentStatus {
  RECORDED
  VERIFIED
  REJECTED
  CANCELLED
}

enum BillPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum ChequeStatus {
  RECEIVED
  DEPOSITED
  CLEARED
  BOUNCED
  RETURNED
  CANCELLED
}

enum StockMovementType {
  OPENING_STOCK
  STOCK_IN
  STOCK_OUT
  SALE
  DM
  ORDER_DISPATCH
  RETURN
  DAMAGE_LOSS
  MANUAL_ADJUSTMENT
}

enum CashSessionStatus {
  OPEN
  CLOSED
  REVIEWED
  LOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalType {
  STOCK_ENTRY
  STOCK_ADJUSTMENT
  DAMAGE_ENTRY
  RATE_CHANGE
  SALE_CORRECTION
  SALE_CANCELLATION
  DM_CANCELLATION
  PAYMENT_CORRECTION
}

enum ExpenseCategory {
  FREIGHT
  COURIER
  PORTER
  TEA
  SNACKS
  TEA_SNACKS
  PETROL
  PACKAGING
  LABOUR
  ELECTRICITY
  INTERNET
  MISC
}

enum GstInvoiceStatus {
  NOT_REQUIRED
  PENDING
  GENERATED
}

enum SummaryStatus {
  DRAFT
  GENERATED
  REVIEWED
  LOCKED
  EXPORTED
}

enum ExportFormat {
  PDF
  CSV
}

enum ExportStatus {
  PENDING
  DONE
  FAILED
}

enum ReturnSourceType {
  SALE
  DELIVERY_MEMO
}

enum ReservationStatus {
  ACTIVE
  DISPATCHED
  CANCELLED
}

enum ReturnStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum ReservationReleaseReason {
  DISPATCH
  CANCEL
  SHORTAGE
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PriceType {
  SELLING
  MINIMUM
  MRP
  PURCHASE
}

enum EntityType {
  USER
  SHOP
  CUSTOMER
  ITEM
  STOCK_LEDGER
  ORDER
  SALE
  DELIVERY_MEMO
  PAYMENT
  CASH_SESSION
  APPROVAL_REQUEST
  INVENTORY_RETURN
  EXPENSE
  STAFF_SHOP_ACCESS
  STOCK_BALANCE
  STOCK_RESERVATION
  WHATSAPP
  WHATSAPP_BROADCAST
}

enum NotificationEvent {
  ORDER_ASSIGNED
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  CHEQUE_BOUNCED
  LOW_STOCK
  PAYMENT_MISMATCH
  WHATSAPP_DLQ
}

enum OrderEventType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_ASSIGNED
  PACKING_STARTED
  ITEM_PACKED
  SHORTAGE_REPORTED
  PAYMENT_ADDED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  MOVEMENT_CREATED
  ENTRY_REQUESTED
  OPENING_SET
  WALKIN_CREATED
  REVIEWED
  CANCELLED
  VOIDED
  APPROVED
  REJECTED
  COMPLETED
  SUBMITTED
  DEPOSITED
  CLEARED
  BOUNCED
  RETURNED
  STAFF_ASSIGNED
}

enum CustomerType {
  WALK_IN
  REGULAR
  BUSINESS
}

// --- MODELS ---

model User {
  id           String     @id @default(cuid())
  name         String
  mobile       String     @unique
  email        String?    @unique
  passwordHash String
  role         RoleName   @default(STAFF)
  status       UserStatus @default(ACTIVE)
  pushToken    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ownedShops             Shop[]               @relation("ShopOwner")
  staffShopAccesses      StaffShopAccess[]
  customersCreated       Customer[]           @relation("CustomerCreatedBy")
  stockMovementsCreated  StockLedger[]        @relation("StockCreatedBy")
  stockMovementsApproved StockLedger[]        @relation("StockApprovedBy")
  ordersCreated          Order[]              @relation("OrderCreatedBy")
  ordersAssigned         Order[]              @relation("OrderAssignedStaff")
  orderEvents            OrderEvent[]
  packingTasks           PackingTask[]
  dispatches             Dispatch[]           @relation("DispatchBy")
  sales                  Sale[]               @relation("SaleStaff")
  deliveryMemos          DeliveryMemo[]       @relation("DeliveryMemoStaff")
  paymentsReceived       Payment[]            @relation("PaymentReceivedBy")
  paymentsVerified       Payment[]            @relation("PaymentVerifiedBy")
  cashSessions           CashSession[]        @relation("CashSessionStaff")
  cashSessionsReviewed   CashSession[]        @relation("CashSessionReviewedBy")
  approvalRequests       ApprovalRequest[]    @relation("ApprovalRequestedBy")
  approvalResponses      ApprovalRequest[]    @relation("ApprovalApprovedBy")
  notifications          Notification[]
  auditLogs              AuditLog[]
  dailySummariesReviewed DailySummary[]       @relation("SummaryReviewedBy")
  dailySummaryExports    DailySummaryExport[]
  returnsCreated         InventoryReturn[]    @relation("ReturnCreatedBy")
  returnsApproved        InventoryReturn[]    @relation("ReturnApprovedBy")
  expensesCreated        Expense[]
  priceChanges           ItemPriceHistory[]
  attendance             Attendance[]
  leaveRequests          LeaveRequest[]

  assignedWaConversations     WaConversation[]
  waBroadcasts                WaBroadcast[]
  assetsCreated               Asset[]               @relation("AssetCreatedBy")
  waTemplateAttributesCreated WaTemplateAttribute[] @relation("WaTemplateAttributeCreatedBy")
  waTemplateVersionsCreated   WaTemplateVersion[]   @relation("WaTemplateVersionCreatedBy")
}

model Shop {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  city      String
  address   String?
  phone     String?
  email     String?
  gstin     String?
  logo      String?
  ownerId   String
  upiId     String?
  upiName   String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  owner            User               @relation("ShopOwner", fields: [ownerId], references: [id])
  staffAccesses    StaffShopAccess[]
  customers        Customer[]
  itemCategories   ItemCategory[]
  items            Item[]
  stockLedger      StockLedger[]
  stockBalances    StockBalance[]
  orders           Order[]
  packingTasks     PackingTask[]
  dispatches       Dispatch[]
  sales            Sale[]
  deliveryMemos    DeliveryMemo[]
  payments         Payment[]
  cashSessions     CashSession[]
  notifications    Notification[]
  dailySummaries   DailySummary[]
  reservations     StockReservation[]
  inventoryReturns InventoryReturn[]
  expenses         Expense[]
  approvalRequests ApprovalRequest[]
  attendance       Attendance[]

  waConversations      WaConversation[]
  waTemplates          WaTemplate[]
  waFlows              WaFlow[]
  waIntegration        WaIntegration?
  waBroadcasts         WaBroadcast[]
  assets               Asset[]
  waTemplateAttributes WaTemplateAttribute[]

  @@index([ownerId])
}

model WaIntegration {
  id                       String                @id @default(cuid())
  shopId                   String                @unique
  verifyToken              String
  accessToken              String
  appSecret                String?
  businessAccountId        String
  phoneNumberId            String
  phoneNumber              String?
  businessName             String?
  status                   WaIntegrationStatus   @default(DISCONNECTED)
  accountStatus            String?
  accountReviewStatus      String?
  displayNameStatus        String?
  capabilities             Json?
  messagingLimitTier       WaMessagingLimitTier?
  qualityRating            WaQualityRating?
  callingEnabled           Boolean               @default(false)
  rsaPublicKey             String?               @db.Text
  rsaPrivateKeyEncrypted   String?               @db.Text
  connectedAt              DateTime?
  lastWebhookAt            DateTime?
  lastManagementEventAt    DateTime?
  lastManagementEventField String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([phoneNumberId])
}

model StaffShopAccess {
  id        String   @id @default(cuid())
  staffId   String
  shopId    String
  createdAt DateTime @default(now())

  staff User @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shop  Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([staffId, shopId])
  @@index([shopId])
}

model Customer {
  id                String       @id @default(cuid())
  shopId            String
  name              String
  type              CustomerType @default(REGULAR)
  phone             String?
  email             String?
  address           String?
  city              String?
  gstin             String?
  contactPerson     String?
  creditLimit       Decimal?     @db.Decimal(12, 2)
  outstandingAmount Decimal      @default(0) @db.Decimal(12, 2)
  advanceBalance    Decimal      @default(0) @db.Decimal(12, 2)
  notes             String?
  status            RecordStatus @default(ACTIVE)
  createdById       String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  shop                  Shop                   @relation(fields: [shopId], references: [id], onDelete: Restrict)
  createdBy             User                   @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  orders                Order[]
  dispatches            Dispatch[]
  sales                 Sale[]
  deliveryMemos         DeliveryMemo[]
  payments              Payment[]
  inventoryReturns      InventoryReturn[]
  waConversations       WaConversation[]
  waFlowExecutions      WaFlowExecution[]
  waBroadcastRecipients WaBroadcastRecipient[]

  @@index([shopId])
  @@index([phone])
  @@index([shopId, phone])
  @@index([shopId, gstin])
  @@index([shopId, email])
}

model ItemCategory {
  id        String       @id @default(cuid())
  shopId    String
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop  Shop   @relation(fields: [shopId], references: [id])
  items Item[]

  @@unique([shopId, name])
}

model Item {
  id                  String                      @id @default(cuid())
  shopId              String
  name                String
  sku                 String?
  categoryId          String?
  unit                String
  defaultSellingPrice Decimal                     @default(0) @db.Decimal(12, 2)
  minimumAllowedPrice Decimal?                    @db.Decimal(12, 2)
  purchasePrice       Decimal?                    @db.Decimal(12, 2)
  mrp                 Decimal?                    @db.Decimal(12, 2)
  minimumStock        Decimal                     @default(0) @db.Decimal(12, 3)
  imageUrl            String?
  status              RecordStatus                @default(ACTIVE)
  embedding           Unsupported("vector(384)")?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  shop                 Shop                  @relation(fields: [shopId], references: [id])
  category             ItemCategory?         @relation(fields: [categoryId], references: [id])
  stockLedger          StockLedger[]
  stockBalance         StockBalance?
  orderItems           OrderItem[]
  dispatchItems        DispatchItem[]
  saleItems            SaleItem[]
  deliveryMemoItems    DeliveryMemoItem[]
  reservations         StockReservation[]
  inventoryReturnItems InventoryReturnItem[]
  priceHistory         ItemPriceHistory[]

  @@unique([shopId, sku])
  @@index([shopId, name])
  @@index([shopId, status])
  @@index([shopId, sku])
}

model StockBalance {
  id             String   @id @default(cuid())
  shopId         String
  itemId         String   @unique
  physicalStock  Decimal  @default(0) @db.Decimal(12, 3)
  reservedStock  Decimal  @default(0) @db.Decimal(12, 3)
  availableStock Decimal  @default(0) @db.Decimal(12, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Restrict)
  item Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([shopId])
  @@index([shopId, availableStock])
}

model ItemPriceHistory {
  id          String    @id @default(cuid())
  itemId      String
  oldPrice    Decimal   @db.Decimal(12, 2)
  newPrice    Decimal   @db.Decimal(12, 2)
  priceType   PriceType
  changedById String
  createdAt   DateTime  @default(now())

  item      Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  changedBy User @relation(fields: [changedById], references: [id])

  @@index([itemId])
  @@index([createdAt])
}

model StockLedger {
  id            String            @id @default(cuid())
  shopId        String
  itemId        String
  movementType  StockMovementType
  quantityIn    Decimal           @default(0) @db.Decimal(12, 3)
  quantityOut   Decimal           @default(0) @db.Decimal(12, 3)
  referenceType String?
  referenceId   String?
  reason        String?
  createdById   String
  approvedById  String?
  createdAt     DateTime          @default(now())

  shop       Shop  @relation(fields: [shopId], references: [id], onDelete: Restrict)
  item       Item  @relation(fields: [itemId], references: [id])
  createdBy  User  @relation("StockCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("StockApprovedBy", fields: [approvedById], references: [id])

  @@index([shopId, itemId])
  @@index([shopId, itemId, createdAt])
  @@index([referenceType, referenceId])
}

model Order {
  id                   String            @id @default(cuid())
  orderNumber          String
  shopId               String
  customerId           String
  createdById          String
  assignedStaffId      String?
  orderDate            DateTime          @default(now())
  expectedDispatchDate DateTime?
  priority             Priority          @default(NORMAL)
  status               OrderStatus       @default(DRAFT)
  paymentStatus        BillPaymentStatus @default(UNPAID)
  subtotal             Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount       Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount           Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount        Decimal           @default(0) @db.Decimal(12, 2)
  ownerNotes           String?
  staffNotes           String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  cancelledAt          DateTime?
  cancelReason         String?

  shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customer      Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy     User               @relation("OrderCreatedBy", fields: [createdById], references: [id])
  assignedStaff User?              @relation("OrderAssignedStaff", fields: [assignedStaffId], references: [id])
  items         OrderItem[]
  events        OrderEvent[]
  packingTasks  PackingTask[]
  dispatches    Dispatch[]
  sales         Sale[]
  deliveryMemos DeliveryMemo[]
  payments      Payment[]
  reservations  StockReservation[]

  @@unique([shopId, orderNumber])
  @@index([shopId, status])
  @@index([shopId, status, createdAt])
  @@index([customerId])
}

model OrderItem {
  id                 String          @id @default(cuid())
  orderId            String
  itemId             String
  quantityOrdered    Decimal         @db.Decimal(12, 3)
  quantityPacked     Decimal         @default(0) @db.Decimal(12, 3)
  quantityDispatched Decimal         @default(0) @db.Decimal(12, 3)
  quantityPending    Decimal         @default(0) @db.Decimal(12, 3)
  rate               Decimal         @db.Decimal(12, 2)
  discountAmount     Decimal         @default(0) @db.Decimal(12, 2)
  lineTotal          Decimal         @db.Decimal(12, 2)
  status             OrderItemStatus @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item          Item              @relation(fields: [itemId], references: [id])
  dispatchItems DispatchItem[]
  reservation   StockReservation?

  @@index([orderId])
  @@index([itemId])
}

model OrderEvent {
  id          String         @id @default(cuid())
  orderId     String
  eventType   OrderEventType
  oldStatus   OrderStatus?
  newStatus   OrderStatus?
  note        String?
  createdById String
  createdAt   DateTime       @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([orderId])
}

model PackingTask {
  id          String        @id @default(cuid())
  orderId     String
  shopId      String
  staffId     String
  status      PackingStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  shop  Shop  @relation(fields: [shopId], references: [id])
  staff User  @relation(fields: [staffId], references: [id])

  @@index([orderId])
  @@index([shopId, status])
  @@index([staffId])
}

model Dispatch {
  id             String         @id @default(cuid())
  orderId        String?
  dmId           String?
  saleId         String?
  customerId     String
  shopId         String
  dispatchedById String
  dispatchDate   DateTime       @default(now())
  status         DispatchStatus @default(CREATED)
  proofImageUrl  String?
  notes          String?
  createdAt      DateTime       @default(now())

  order        Order?         @relation(fields: [orderId], references: [id])
  deliveryMemo DeliveryMemo?  @relation(fields: [dmId], references: [id])
  sale         Sale?          @relation(fields: [saleId], references: [id])
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shop         Shop           @relation(fields: [shopId], references: [id])
  dispatchedBy User           @relation("DispatchBy", fields: [dispatchedById], references: [id])
  items        DispatchItem[]

  @@index([shopId, dispatchDate])
}

model DispatchItem {
  id                 String  @id @default(cuid())
  dispatchId         String
  orderItemId        String
  itemId             String
  quantityDispatched Decimal @db.Decimal(12, 3)

  dispatch  Dispatch  @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
}

model Sale {
  id                    String            @id @default(cuid())
  saleNumber            String
  shopId                String
  staffId               String
  customerId            String
  orderId               String?
  dmId                  String?
  isWalkin              Boolean           @default(false)
  gstRequired           Boolean           @default(false)
  gstInvoiceStatus      GstInvoiceStatus  @default(NOT_REQUIRED)
  gstInvoiceNumber      String?
  gstInvoiceGeneratedAt DateTime?
  subtotal              Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount        Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount            Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount         Decimal           @default(0) @db.Decimal(12, 2)
  paymentStatus         BillPaymentStatus @default(UNPAID)
  saleStatus            SaleStatus        @default(DRAFT)
  customerSignature     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  cancelledAt           DateTime?
  cancelReason          String?

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  staff            User              @relation("SaleStaff", fields: [staffId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order            Order?            @relation(fields: [orderId], references: [id])
  deliveryMemo     DeliveryMemo?     @relation(fields: [dmId], references: [id])
  items            SaleItem[]
  dispatches       Dispatch[]
  payments         Payment[]
  inventoryReturns InventoryReturn[]

  @@unique([shopId, saleNumber])
  @@index([shopId, createdAt])
  @@index([customerId])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  itemId         String
  quantity       Decimal @db.Decimal(12, 3)
  rate           Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model DeliveryMemo {
  id                  String             @id @default(cuid())
  dmNumber            String
  shopId              String
  orderId             String?
  staffId             String
  customerId          String
  estimatedAmount     Decimal            @default(0) @db.Decimal(12, 2)
  paidAmount          Decimal            @default(0) @db.Decimal(12, 2)
  balanceAmount       Decimal            @default(0) @db.Decimal(12, 2)
  status              DeliveryMemoStatus @default(CREATED)
  paymentStatus       BillPaymentStatus  @default(UNPAID)
  expectedPaymentDate DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  order            Order?             @relation(fields: [orderId], references: [id])
  staff            User               @relation("DeliveryMemoStaff", fields: [staffId], references: [id])
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items            DeliveryMemoItem[]
  dispatches       Dispatch[]
  sales            Sale[]
  payments         Payment[]
  inventoryReturns InventoryReturn[]

  @@unique([shopId, dmNumber])
  @@index([shopId, status])
  @@index([customerId])
}

model DeliveryMemoItem {
  id             String  @id @default(cuid())
  dmId           String
  itemId         String
  quantity       Decimal @db.Decimal(12, 3)
  returnedQty    Decimal @default(0) @db.Decimal(12, 3)
  rate           Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  deliveryMemo DeliveryMemo @relation(fields: [dmId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model Payment {
  id              String        @id @default(cuid())
  shopId          String
  saleId          String?
  dmId            String?
  orderId         String?
  customerId      String
  paymentMode     PaymentMode
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(RECORDED)
  cashSessionId   String?
  receivedById    String
  receivedAt      DateTime      @default(now())
  verifiedById    String?
  verifiedAt      DateTime?
  referenceNumber String?
  proofImageUrl   String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shop         Shop           @relation(fields: [shopId], references: [id], onDelete: Restrict)
  sale         Sale?          @relation(fields: [saleId], references: [id], onDelete: Restrict)
  deliveryMemo DeliveryMemo?  @relation(fields: [dmId], references: [id], onDelete: Restrict)
  order        Order?         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashSession  CashSession?   @relation(fields: [cashSessionId], references: [id])
  receivedBy   User           @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
  verifiedBy   User?          @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id])
  details      PaymentDetail?

  @@index([shopId, receivedAt])
  @@index([shopId, createdAt])
  @@index([customerId])
  @@index([saleId])
}

model PaymentDetail {
  id             String        @id @default(cuid())
  paymentId      String        @unique
  upiReference   String?
  bankUtr        String?
  chequeNumber   String?
  chequeBankName String?
  chequeDate     DateTime?
  chequeStatus   ChequeStatus?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model CashSession {
  id                String            @id @default(cuid())
  shopId            String
  staffId           String
  previousSessionId String?
  openingCash       Decimal           @default(0) @db.Decimal(12, 2)
  expectedCash      Decimal           @default(0) @db.Decimal(12, 2)
  actualCash        Decimal?          @db.Decimal(12, 2)
  cashHandover      Decimal?          @db.Decimal(12, 2)
  difference        Decimal?          @db.Decimal(12, 2)
  differenceReason  String?
  status            CashSessionStatus @default(OPEN)
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  reviewedById      String?
  reviewedAt        DateTime?

  shop            Shop          @relation(fields: [shopId], references: [id])
  staff           User          @relation("CashSessionStaff", fields: [staffId], references: [id])
  reviewedBy      User?         @relation("CashSessionReviewedBy", fields: [reviewedById], references: [id])
  payments        Payment[]
  previousSession CashSession?  @relation("SessionChain", fields: [previousSessionId], references: [id])
  nextSessions    CashSession[] @relation("SessionChain")

  @@index([shopId, openedAt])
  @@index([staffId, status])
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  shopId         String
  type           ApprovalType
  entityType     EntityType
  entityId       String
  payloadJson    Json
  reason         String
  requestedById  String
  status         ApprovalStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  shop        Shop  @relation(fields: [shopId], references: [id])
  requestedBy User  @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User? @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])

  @@index([shopId, status])
  @@index([entityType, entityId])
}

model Notification {
  id           String            @id @default(cuid())
  userId       String
  shopId       String
  triggerEvent NotificationEvent
  entityType   EntityType
  entityId     String?
  message      String
  isRead       Boolean           @default(false)
  createdAt    DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id])

  @@index([userId, isRead])
  @@index([userId, isRead, createdAt])
  @@index([shopId])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  shopId       String?
  action       AuditAction
  entityType   EntityType
  entityId     String?
  oldValueJson Json?
  newValueJson Json?
  reason       String?
  createdAt    DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt])
  @@index([entityType, entityId])
}

model DailySummary {
  id                 String        @id @default(cuid())
  shopId             String
  summaryDate        DateTime      @db.Date
  status             SummaryStatus @default(DRAFT)
  openingCash        Decimal       @default(0) @db.Decimal(12, 2)
  expectedCash       Decimal       @default(0) @db.Decimal(12, 2)
  actualCash         Decimal?      @db.Decimal(12, 2)
  cashDifference     Decimal?      @db.Decimal(12, 2)
  totalSales         Decimal       @default(0) @db.Decimal(12, 2)
  walkinSales        Decimal       @default(0) @db.Decimal(12, 2)
  totalCashCollected Decimal       @default(0) @db.Decimal(12, 2)
  totalUpiCollected  Decimal       @default(0) @db.Decimal(12, 2)
  totalBankCollected Decimal       @default(0) @db.Decimal(12, 2)
  totalCreditPending Decimal       @default(0) @db.Decimal(12, 2)
  ordersCreatedCount Int           @default(0)
  salesCount         Int           @default(0)
  dmCreatedCount     Int           @default(0)
  expenseCount       Int           @default(0)
  payloadJson        Json?
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  shop       Shop                 @relation(fields: [shopId], references: [id])
  reviewedBy User?                @relation("SummaryReviewedBy", fields: [reviewedById], references: [id])
  exports    DailySummaryExport[]

  @@unique([shopId, summaryDate])
  @@index([summaryDate])
}

model DailySummaryExport {
  id             String       @id @default(cuid())
  dailySummaryId String
  format         ExportFormat
  status         ExportStatus @default(PENDING)
  fileUrl        String?
  exportedById   String
  exportedAt     DateTime     @default(now())

  dailySummary DailySummary @relation(fields: [dailySummaryId], references: [id], onDelete: Cascade)
  exportedBy   User         @relation(fields: [exportedById], references: [id])

  @@index([dailySummaryId])
}

model StockReservation {
  id             String                    @id @default(cuid())
  shopId         String
  orderId        String
  orderItemId    String                    @unique
  itemId         String
  reservedQty    Decimal                   @db.Decimal(12, 3)
  packedQty      Decimal                   @default(0) @db.Decimal(12, 3)
  status         ReservationStatus         @default(ACTIVE)
  releasedAt     DateTime?
  releasedReason ReservationReleaseReason?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  shop      Shop      @relation(fields: [shopId], references: [id])
  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])

  @@index([shopId, status])
  @@index([itemId, status])
}

model InventoryReturn {
  id           String           @id @default(cuid())
  returnNumber String           @unique
  shopId       String
  customerId   String
  saleId       String?
  dmId         String?
  sourceType   ReturnSourceType
  netAmount    Decimal          @db.Decimal(12, 2)
  status       ReturnStatus     @default(PENDING)
  notes        String?
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  shop         Shop                  @relation(fields: [shopId], references: [id])
  customer     Customer              @relation(fields: [customerId], references: [id])
  sale         Sale?                 @relation(fields: [saleId], references: [id])
  deliveryMemo DeliveryMemo?         @relation(fields: [dmId], references: [id])
  createdBy    User                  @relation("ReturnCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?                 @relation("ReturnApprovedBy", fields: [approvedById], references: [id])
  items        InventoryReturnItem[]

  @@index([shopId, status])
  @@index([customerId])
}

model InventoryReturnItem {
  id                String  @id @default(cuid())
  inventoryReturnId String
  itemId            String
  quantity          Decimal @db.Decimal(12, 3)
  rate              Decimal @db.Decimal(12, 2)
  totalAmount       Decimal @db.Decimal(12, 2)

  return InventoryReturn @relation(fields: [inventoryReturnId], references: [id], onDelete: Cascade)
  item   Item            @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model Expense {
  id          String          @id @default(cuid())
  shopId      String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  note        String?
  photoUrl    String?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  shop      Shop @relation(fields: [shopId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([shopId, createdAt])
}

model Attendance {
  id        String           @id @default(cuid())
  shopId    String
  staffId   String
  date      DateTime         @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  shop  Shop @relation(fields: [shopId], references: [id])
  staff User @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([shopId, date])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  staffId      String
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String
  status       LeaveStatus @default(PENDING)
  approvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  staff User @relation(fields: [staffId], references: [id])

  @@index([staffId])
}

// --- WHATSAPP MODELS ---

enum WaMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  DELETED
}

enum WaMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  STICKER
  TEMPLATE
  FLOW
  INTERACTIVE
  LOCATION
  CONTACT_CARD
  REACTION
  ORDER
  SYSTEM
  UNSUPPORTED
}

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaIntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WaFlowStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
  BLOCKED
  THROTTLED
}

enum WaFlowExecutionStatus {
  STARTED
  OPENED
  SUBMITTED
  COMPLETED
  CANCELLED
  FAILED
  EXPIRED
}

enum WaTemplateStatus {
  APPROVED
  REJECTED
  PENDING
  PAUSED
  DISABLED
  IN_APPEAL
  DELETED
}

enum WaBroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum WaBroadcastRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum WaMessagingLimitTier {
  TIER_250
  TIER_1K
  TIER_10K
  TIER_100K
  UNLIMITED
}

enum WaQualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

enum WaTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

enum WaTemplateAttributeType {
  TEXT
  NUMBER
  CURRENCY
  DATE
  DATETIME
  BOOLEAN
  URL
  PHONE
  EMAIL
}

enum WaTemplateAttributeSource {
  SYSTEM
  CUSTOMER
  CONVERSATION
  SHOP
  CUSTOM
}

enum WaTemplateMappingStatus {
  VALID
  INCOMPLETE
  INVALID
}

enum AssetKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  OTHER
}

enum AssetStatus {
  UPLOADING
  READY
  FAILED
  DELETED
}

enum AssetSource {
  WHATSAPP_INBOUND
  WHATSAPP_OUTBOUND
  INTERNAL
}

enum AssetStorageProvider {
  S3
}

model Asset {
  id               String                @id @default(cuid())
  shopId           String
  createdById      String?
  kind             AssetKind
  source           AssetSource
  status           AssetStatus           @default(UPLOADING)
  storageProvider  AssetStorageProvider?
  storageBucket    String?
  storageKey       String?
  remoteUrl        String?
  externalProvider String?
  externalId       String?
  mimeType         String
  fileName         String?
  sizeBytes        BigInt?
  checksumSha256   String?
  width            Int?
  height           Int?
  durationMs       Int?
  metadata         Json?
  errorMessage     String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  readyAt          DateTime?
  deletedAt        DateTime?

  shop       Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy  User?       @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  waMessages WaMessage[]

  @@unique([shopId, storageProvider, storageBucket, storageKey])
  @@unique([shopId, externalProvider, externalId])
  @@index([shopId, status, createdAt])
  @@index([createdById])
}

model WaConversation {
  id                    String    @id @default(cuid())
  shopId                String
  customerId            String?
  phone                 String
  bsuid                 String?
  contactName           String?
  lastCustomerMessageAt DateTime?
  unreadCount           Int       @default(0)
  isArchived            Boolean   @default(false)
  isPinned              Boolean   @default(false)
  assignedToId          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  shop           Shop              @relation(fields: [shopId], references: [id])
  customer       Customer?         @relation(fields: [customerId], references: [id])
  assignedTo     User?             @relation(fields: [assignedToId], references: [id])
  messages       WaMessage[]
  flowExecutions WaFlowExecution[]

  @@unique([shopId, phone])
  @@index([shopId, updatedAt])
  @@index([shopId, customerId])
}

model WaMessage {
  id                   String             @id @default(cuid())
  conversationId       String
  metaMessageId        String?            @unique
  replyToMetaMessageId String?
  direction            WaMessageDirection
  status               WaMessageStatus    @default(QUEUED)
  type                 WaMessageType      @default(TEXT)
  content              Json? // Text content or media metadata
  payload              Json?
  assetId              String?
  templateId           String?
  templateName         String?
  templateLanguage     String?
  broadcastRecipientId String?
  retryCount           Int                @default(0)
  lastRetryAt          DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  failedAt             DateTime?
  errorMessage         String?
  createdAt            DateTime           @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id])
  asset        Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([assetId])
}

enum WaWebhookEventType {
  STATUS
  MESSAGE
}

enum WaWebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  QUARANTINED
}

model WaWebhookEnvelope {
  id                String                    @id @default(cuid())
  shopId            String
  wabaId            String?
  phoneNumberId     String?
  field             String
  payloadJson       Json
  payloadHash       String
  signatureVerified Boolean                   @default(false)
  processingStatus  WaWebhookProcessingStatus @default(RECEIVED)
  attemptCount      Int                       @default(0)
  errorCode         String?
  errorMessage      String?
  receivedAt        DateTime                  @default(now())
  processedAt       DateTime?

  @@unique([shopId, payloadHash])
  @@index([shopId, processingStatus, receivedAt])
  @@index([field, receivedAt])
}

model WaWebhookEvent {
  id          String             @id // Composite or hash ID
  shopId      String?
  eventType   WaWebhookEventType
  processedAt DateTime           @default(now())

  @@index([processedAt])
}

model WaTemplate {
  id                  String                  @id @default(cuid())
  shopId              String
  metaTemplateId      String?
  name                String
  language            String
  status              WaTemplateStatus        @default(PENDING)
  category            WaTemplateCategory
  components          Json
  headerVariables     Json?
  bodyVariables       Json?
  qualityScore        String?
  sentCount           Int                     @default(0)
  readCount           Int                     @default(0)
  metaRejectionReason String?
  statusUpdatedAt     DateTime?
  qualityUpdatedAt    DateTime?
  syncedAt            DateTime?
  subtype             String?
  parameterFormat     String                  @default("POSITIONAL")
  mappingStatus       WaTemplateMappingStatus @default(INCOMPLETE)
  draftDefinition     Json?
  rawMeta             Json?
  syncError           String?
  deletedAt           DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  shop             Shop                        @relation(fields: [shopId], references: [id])
  broadcasts       WaBroadcast[]
  variableMappings WaTemplateVariableMapping[]
  versions         WaTemplateVersion[]

  @@unique([shopId, name, language])
  @@index([shopId, status])
}

model WaTemplateAttribute {
  id            String                    @id @default(cuid())
  shopId        String
  key           String
  label         String
  type          WaTemplateAttributeType   @default(TEXT)
  source        WaTemplateAttributeSource @default(CUSTOM)
  sourcePath    String?
  fallbackValue String?
  description   String?
  isSystem      Boolean                   @default(false)
  isActive      Boolean                   @default(true)
  createdById   String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  shop      Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy User?                       @relation("WaTemplateAttributeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  mappings  WaTemplateVariableMapping[]

  @@unique([shopId, key])
  @@index([shopId, isActive])
}

model WaTemplateVariableMapping {
  id            String   @id @default(cuid())
  templateId    String
  component     String
  position      Int
  buttonIndex   Int?
  cardIndex     Int?
  attributeId   String?
  sampleValue   String
  fallbackValue String?
  required      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  template  WaTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  attribute WaTemplateAttribute? @relation(fields: [attributeId], references: [id], onDelete: SetNull)

  @@unique([templateId, component, position, buttonIndex, cardIndex])
  @@index([templateId])
  @@index([attributeId])
}

model WaTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  definition  Json
  metaStatus  String?
  createdById String?
  createdAt   DateTime @default(now())

  template  WaTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("WaTemplateVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([templateId, version])
  @@index([templateId, createdAt])
}

model WaTemplateUsage {
  id         String @id @default(cuid())
  templateId String
  sentCount  Int    @default(0)
  readCount  Int    @default(0)
  replyCount Int    @default(0)
}

model WaFlow {
  id               String       @id @default(cuid())
  shopId           String
  flowId           String?
  name             String
  description      String?
  status           WaFlowStatus @default(DRAFT)
  categories       Json?
  flowJson         Json?
  jsonVersion      String?
  dataApiVersion   String?
  validationErrors Json?
  endpointEnabled  Boolean      @default(false)
  endpointKey      String?      @unique
  endpointUrl      String?
  endpointHealth   Json?
  handlerKey       String?
  previewUrl       String?
  previewExpiresAt DateTime?
  localRevision    Int          @default(1)
  deployedRevision Int?
  rawMeta          Json?
  syncError        String?
  totalSent        Int          @default(0)
  totalResponses   Int          @default(0)
  syncedAt         DateTime?
  publishedAt      DateTime?
  deprecatedAt     DateTime?
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  shop       Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  executions WaFlowExecution[]

  @@unique([shopId, flowId])
  @@index([shopId, status, updatedAt])
}

model WaFlowExecution {
  id                String                @id @default(cuid())
  shopId            String
  flowId            String
  conversationId    String
  customerId        String?
  metaMessageId     String?
  flowToken         String?               @unique
  flowTokenHash     String?
  idempotencyKey    String?
  status            WaFlowExecutionStatus @default(STARTED)
  currentScreen     String?
  lastAction        String?
  attemptCount      Int                   @default(0)
  lastEndpointError String?
  inputJson         Json?
  resultJson        Json?
  sentAt            DateTime?
  openedAt          DateTime?
  submittedAt       DateTime?
  startedAt         DateTime              @default(now())
  completedAt       DateTime?
  cancelledAt       DateTime?
  expiresAt         DateTime?

  waFlow       WaFlow         @relation(fields: [flowId], references: [id])
  conversation WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?      @relation(fields: [customerId], references: [id])

  @@index([shopId, flowId])
  @@index([flowToken])
  @@index([idempotencyKey])
  @@index([conversationId, startedAt])
}

model WaBroadcast {
  id                String            @id @default(cuid())
  shopId            String
  name              String
  templateId        String?
  templateVariables Json?
  audienceFilter    Json?
  audienceCount     Int               @default(0)
  status            WaBroadcastStatus @default(DRAFT)
  sentCount         Int               @default(0)
  deliveredCount    Int               @default(0)
  readCount         Int               @default(0)
  failedCount       Int               @default(0)
  skippedCount      Int               @default(0)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdById       String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shop       Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  template   WaTemplate?            @relation(fields: [templateId], references: [id])
  createdBy  User                   @relation(fields: [createdById], references: [id])
  recipients WaBroadcastRecipient[]

  @@index([shopId, status])
}

model WaBroadcastRecipient {
  id            String                     @id @default(cuid())
  broadcastId   String
  customerId    String
  customerName  String?
  customerPhone String
  status        WaBroadcastRecipientStatus @default(PENDING)
  metaMessageId String?
  errorMessage  String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime                   @default(now())

  broadcast WaBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  customer  Customer    @relation(fields: [customerId], references: [id])

  @@unique([broadcastId, customerId])
  @@index([broadcastId, status])
}
