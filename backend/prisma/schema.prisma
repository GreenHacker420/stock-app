  reviewedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  shop       Shop                 @relation(fields: [shopId], references: [id])
  reviewedBy User?                @relation("SummaryReviewedBy", fields: [reviewedById], references: [id])
