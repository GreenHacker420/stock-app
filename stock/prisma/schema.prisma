generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["reactNative"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./app.db"
}

model LocalCustomer {
  id             String    @id
  serverId       String?
  shopId         String
  name           String
  phone          String?
  email          String?
  gstin          String?
  address        String?
  city           String?
  customerType   String?
  syncStatus     String
  conflictReason String?
  createdAt      DateTime
  updatedAt      DateTime
  deletedAt      DateTime?

  @@index([shopId])
  @@index([serverId])
  @@index([phone])
  @@index([syncStatus])
}

model LocalItem {
  id                String   @id
  serverId          String?
  shopId            String
  name              String
  sku               String?
  categoryId        String?
  categoryName      String?
  unit              String?
  price             String
  stockQty          String
  pendingStockDelta String
  syncStatus        String
  updatedAt         DateTime

  @@index([shopId])
  @@index([serverId])
  @@index([sku])
  @@index([syncStatus])
}

model LocalSale {
  id               String   @id
  serverId         String?
  shopId           String
  customerId       String?
  serverCustomerId String?
  billNumber       String?
  subtotal         String
  discount         String
  tax              String
  total            String
  paymentStatus    String
  notes            String?
  signatureUri     String?
  signatureBase64  String?
  syncStatus       String
  conflictReason   String?
  createdAt        DateTime
  updatedAt        DateTime

  @@index([shopId])
  @@index([serverId])
  @@index([customerId])
  @@index([serverCustomerId])
  @@index([syncStatus])
  @@index([createdAt])
}

model LocalSaleItem {
  id             String   @id
  saleId         String
  itemId         String?
  serverItemId   String?
  nameSnapshot   String
  priceSnapshot  String
  quantity       String
  unit           String?
  lineTotal      String
  createdAt      DateTime

  @@index([saleId])
  @@index([itemId])
  @@index([serverItemId])
}

model LocalPayment {
  id               String   @id
  serverId         String?
  saleId           String?
  serverSaleId     String?
  customerId       String?
  serverCustomerId String?
  shopId           String
  amount           String
  mode             String
  reference        String?
  notes            String?
  syncStatus       String
  createdAt        DateTime
  updatedAt        DateTime

  @@index([shopId])
  @@index([serverId])
  @@index([saleId])
  @@index([serverSaleId])
  @@index([customerId])
  @@index([syncStatus])
}

model PendingMutation {
  id                  String   @id
  idempotencyKey      String   @unique
  shopId              String
  userId              String?
  deviceId            String?
  entityType          String
  action              String
  localEntityId       String
  serverEntityId      String?
  dependsOnMutationId String?
  payloadJson         String
  status              String
  retryCount          Int
  lastError           String?
  createdAt           DateTime
  updatedAt           DateTime

  @@index([shopId])
  @@index([status])
  @@index([entityType])
  @@index([localEntityId])
  @@index([dependsOnMutationId])
  @@index([createdAt])
}

model IdMapping {
  localId    String   @id
  serverId   String
  entityType String
  createdAt  DateTime

  @@index([serverId])
  @@index([entityType])
}

model SyncMetadata {
  key       String   @id
  value     String
  updatedAt DateTime
}
