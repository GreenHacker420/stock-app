{
  "expo": {
    "name": "stock",
    "slug": "stock",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "stock",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stock"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.stock",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "style": "dark"
        }
      ],
      "expo-notifications",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png"
        }
      ],
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow ShopControl to use Face ID for quick login."
        }
      ],
      "expo-sharing",
      [
        "expo-truecaller",
        {
          "androidClientId": "ksaranwfztxrftq7zzf5rqy7gp2olcdj6s6s0pneolw"
        }
      ],
      "expo-sqlite",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow ShopControl to access your contacts to link conversations with your customers."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ShopControl to share your current location in WhatsApp conversations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ShopControl to select photos and videos for WhatsApp conversations."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow ShopControl to record voice messages for WhatsApp conversations."
        }
      ],
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "12c8d189-6ace-4eb9-91ab-21c6acaf206e"
      }
    }
  }
}
