{
  "expo": {
    "name": "stock",
    "slug": "stock",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "stock",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stock"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.stock",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "androidNavigationBar": {
      "visible": true,
      "backgroundColor": "#fbfcfb",
      "barStyle": "dark-content"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png"
        }
      ],
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow ShopControl to use Face ID for quick login."
        }
      ],
      "expo-sharing",
      [
        "expo-truecaller",
        {
          "androidClientId": "ksaranwfztxrftq7zzf5rqy7gp2olcdj6s6s0pneolw"
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "12c8d189-6ace-4eb9-91ab-21c6acaf206e"
      }
    }
  }
}
